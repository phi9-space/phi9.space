---
import BaseLayout from "@layouts/BaseLayout.astro";
import { contactEmail, contactMailto } from "@lib/site";
---

<BaseLayout
	title="Collaborations — phi9.space"
	description="Partner with phi9.space on physical AI research, data capture, and deployment."
	fullWidth={true}
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Collaborations</span>
      <h1>Work with us</h1>
      <p class="page-hero__sub">
        We partner with labs, universities, and companies building the next generation of physical AI systems.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="empty-state">
        <p>Interested in collaborating? Reach out at <a href={contactMailto}>{contactEmail}</a></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: clamp(7rem, 12vw, 10rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .page-hero .container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
  }

  .page-hero h1 { max-width: 20ch; margin: 0; }

  .page-hero__sub {
    max-width: 50ch;
    color: var(--color-muted);
    margin: 0;
  }

  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--color-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-state p { margin: 0; }
</style>
