---
import manifest from "@generated/vault-manifest.json";
import VaultLayout from "@layouts/VaultLayout.astro";
import ModelCard from "@components/ModelCard.astro";

const datasets = (manifest.nodes || [])
	.filter((node) => node.type === "dataset")
	.slice()
	.sort((a, b) => {
		const aDate = a.updated ? new Date(a.updated) : new Date(0);
		const bDate = b.updated ? new Date(b.updated) : new Date(0);
		return bDate.valueOf() - aDate.valueOf();
	});

const modelCards = datasets.filter((entry) => entry.datasetKind === "model-card");
const featuredDatasets = datasets.filter((entry) => entry.featured);
const regularDatasets = datasets.filter((entry) => !entry.featured);
---

<VaultLayout
	title="Datasets — phi9.space"
	description="High-fidelity robotics training datasets with full-body motion capture, multi-view video, and comprehensive metadata."
>
  <section class="hero">
    <p class="section-kicker">Datasets</p>
    <h1>Robotics Training Data</h1>
    <p class="hero-description">
      Full-body motion capture datasets for robot learning. 23 DOF at 120 Hz, 
      synchronized multi-view video, and comprehensive task metadata.
    </p>
  </section>

  {featuredDatasets.length > 0 && (
    <section class="featured-section">
      <h2>Featured Datasets</h2>
      <div class="card-grid card-grid--featured">
        {featuredDatasets.map((dataset) => (
          <ModelCard
            title={dataset.title}
            description={dataset.excerpt || ""}
            slug={dataset.slug}
            tier={2}
            domain="tabletop"
            taskType="pick-place"
            status={dataset.status}
            updated={dataset.updated}
            featured={true}
          />
        ))}
      </div>
    </section>
  )}

  <section class="datasets-section">
    <div class="section-header">
      <h2>All Datasets</h2>
      <span class="count">{datasets.length} dataset{datasets.length !== 1 ? 's' : ''}</span>
    </div>
    
    {datasets.length > 0 ? (
      <div class="card-grid">
        {datasets.map((dataset) => (
          <ModelCard
            title={dataset.title}
            description={dataset.excerpt || ""}
            slug={dataset.slug}
            tier={2}
            domain="tabletop"
            taskType="pick-place"
            status={dataset.status}
            updated={dataset.updated}
            featured={dataset.featured}
          />
        ))}
      </div>
    ) : (
      <p class="empty-hint">
        No datasets published yet. Use the publishing guide at <a href="/lab/publishing">/lab/publishing</a> to
        add your first dataset.
      </p>
    )}
  </section>

  <section class="info-section">
    <h2>Dataset Features</h2>
    <div class="features-grid">
      <div class="feature">
        <h3>🎯 Full-Body Motion Capture</h3>
        <p>23 body segments at 120 Hz — complete kinematic chain from pelvis to fingertips.</p>
      </div>
      <div class="feature">
        <h3>📹 Multi-View Video</h3>
        <p>Synchronized 3-view RGB video at 60 fps with egocentric, overhead, and side cameras.</p>
      </div>
      <div class="feature">
        <h3>🏷️ Rich Metadata</h3>
        <p>Per-episode language instructions, task labels, success/failure flags, and object annotations.</p>
      </div>
      <div class="feature">
        <h3>🤖 Robot-Ready Formats</h3>
        <p>Export to LeRobot, HDF5, MuJoCo, Isaac Sim, and ROS2 MCAP formats.</p>
      </div>
    </div>
  </section>
</VaultLayout>

<style>
  .hero {
    margin-bottom: 2rem;
  }

  .section-kicker {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero h1 {
    margin: 0.5rem 0;
    font-size: 2rem;
    line-height: 1.2;
  }

  .hero-description {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 60ch;
    line-height: 1.6;
  }

  .featured-section {
    margin-bottom: 2.5rem;
  }

  .featured-section h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .datasets-section {
    margin-bottom: 2.5rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .count {
    font-size: 0.85rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .card-grid--featured {
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-hint {
    margin: 0;
    color: var(--color-muted);
    padding: 2rem;
    text-align: center;
    background: var(--color-surface);
    border-radius: 0.5rem;
    border: 1px dashed var(--color-border);
  }

  .info-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .info-section h2 {
    margin-bottom: 1.25rem;
    font-size: 1.25rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .feature p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>