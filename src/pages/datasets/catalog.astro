---
import manifest from "@generated/vault-manifest.json";
import VaultLayout from "@layouts/VaultLayout.astro";

const entries = (manifest.nodes || [])
	.filter((node) => node.type === "dataset" && node.datasetKind !== "model-card")
	.slice()
	.sort((a, b) => {
		const aDate = a.updated ? new Date(a.updated) : new Date(0);
		const bDate = b.updated ? new Date(b.updated) : new Date(0);
		return bDate.valueOf() - aDate.valueOf();
	});
---

<VaultLayout
	title="Dataset Catalog — phi9.space"
	description="Addressable catalog index sourced from vault datasets."
>
  <section>
    <p class="section-kicker">Datasets</p>
    <h1>Catalog</h1>
    <p class="section-intro">Direct index for dataset catalog entries from vault.</p>
  </section>

  {
    entries.length > 0 ? (
      <section class="note-grid">
        {entries.map((entry) => (
          <article class="note-card">
            <h3>
              <a href={`/datasets/${entry.slug}/`}>{entry.title}</a>
            </h3>
            <p>{entry.excerpt}</p>
            <div class="note-card__meta">
              <span>{entry.category}</span>
              <span>{entry.datasetKind || "catalog"}</span>
              {entry.updated && <span>{new Date(entry.updated).toLocaleDateString()}</span>}
            </div>
          </article>
        ))}
      </section>
    ) : (
      <p>No catalog entries yet. See <a href="/lab/publishing">/lab/publishing</a> for the publishing workflow.</p>
    )
  }
</VaultLayout>

<style>
  .section-kicker {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .section-intro {
    margin-top: 0.35rem;
    color: var(--color-muted);
  }
</style>
