---
import { getEntry } from "astro:content";
import manifest from "@generated/vault-manifest.json";
import BaseLayout from "@layouts/BaseLayout.astro";
import { buildDatasetTabs } from "@lib/dataset-tabs";
import { marked } from "marked";

export async function getStaticPaths() {
	return (manifest.nodes || [])
		.filter((node) => node.type === "dataset")
		.map((node) => ({
			params: { slug: node.slug },
		}));
}

const slug = Astro.params.slug || "";
const entry = await getEntry("vault", slug);

if (!entry || entry.data.type !== "dataset") {
	throw new Error(`Dataset note missing for slug: ${slug}`);
}

const tabs = buildDatasetTabs(entry.body);
const firstTabId = tabs[0]?.id || "overview";
const renderedTabs = tabs.map((tab) => ({
	...tab,
	html: marked.parse(tab.content, { async: false }),
}));

const updatedLabel = entry.data.updated
	? new Date(entry.data.updated).toLocaleDateString()
	: entry.data.date
		? new Date(entry.data.date).toLocaleDateString()
		: "Not set";

const metadataItems = [
	{ key: "Category", value: entry.data.category },
	{ key: "Dataset Kind", value: entry.data.datasetKind },
	{ key: "Status", value: entry.data.status },
	{ key: "Updated", value: updatedLabel },
	{ key: "Series", value: entry.data.series || "" },
	{ key: "Featured", value: entry.data.featured ? "Yes" : "" },
].filter((item) => item.value);

const canonicalPath = `/datasets/${entry.slug}/`;
---

<BaseLayout
	title={`${entry.data.title} — Datasets — phi9.space`}
	description={entry.data.description || "Dataset detail page for phi9.space."}
	pageType="article"
>
  <article class="dataset-detail">
    <section class="dataset-main">
      <header class="dataset-header">
        <p class="dataset-kicker">Dataset</p>
        <h1>{entry.data.title}</h1>
        {entry.data.description && <p class="dataset-description">{entry.data.description}</p>}

        {entry.data.tags.length > 0 && (
          <p class="dataset-tags">
            {entry.data.tags.map((tag) => (
              <a href={`/vault/tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
            ))}
          </p>
        )}

        <div class="dataset-actions">
          <a href="/vault/">Open Vault Shell</a>
          <a href="/vault/graph/">Open Graph</a>
          <a href="/datasets/">Back to Datasets</a>
        </div>
      </header>

      {
        renderedTabs.length > 0 ? (
          <section class="dataset-tabs" data-dataset-tabs data-default-tab={firstTabId}>
            <div class="dataset-tab-list" role="tablist" aria-label="Dataset sections">
              {renderedTabs.map((tab) => (
                <button
                  type="button"
                  class="dataset-tab-trigger"
                  role="tab"
                  aria-selected={tab.id === firstTabId ? "true" : "false"}
                  data-tab-target={tab.id}
                >
                  {tab.label}
                </button>
              ))}
            </div>

            <div class="dataset-tab-panels">
              {renderedTabs.map((tab) => (
                <section
                  role="tabpanel"
                  class="dataset-tab-panel"
                  data-tab-panel={tab.id}
                  hidden={tab.id !== firstTabId}
                >
                  <div class="dataset-tab-markdown" set:html={tab.html}></div>
                </section>
              ))}
            </div>
          </section>
        ) : (
          <p class="dataset-empty">
            No sections found yet. Add markdown sections to this note, then review the publishing guide at
            <a href="/lab/publishing"> /lab/publishing</a>.
          </p>
        )
      }
    </section>

    <aside class="dataset-meta" aria-label="Dataset metadata">
      <h2>Metadata</h2>
      <dl>
        {metadataItems.map((item) => (
          <>
            <dt>{item.key}</dt>
            <dd>{item.value}</dd>
          </>
        ))}
        <dt>Canonical URL</dt>
        <dd>
          <a href={canonicalPath}>{canonicalPath}</a>
        </dd>
      </dl>
    </aside>
  </article>

  <script is:inline>
    const tabRoot = document.querySelector("[data-dataset-tabs]");
    if (tabRoot) {
      const triggers = Array.from(tabRoot.querySelectorAll("[data-tab-target]"));
      const panels = Array.from(tabRoot.querySelectorAll("[data-tab-panel]"));

      const activateTab = (tabId) => {
        triggers.forEach((trigger) => {
          const isActive = trigger.getAttribute("data-tab-target") === tabId;
          trigger.setAttribute("aria-selected", isActive ? "true" : "false");
          trigger.classList.toggle("is-active", isActive);
        });

        panels.forEach((panel) => {
          const isActive = panel.getAttribute("data-tab-panel") === tabId;
          panel.hidden = !isActive;
        });
      };

      const defaultTab = tabRoot.getAttribute("data-default-tab");
      if (defaultTab) activateTab(defaultTab);

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const tabId = trigger.getAttribute("data-tab-target");
          if (tabId) activateTab(tabId);
        });
      });
    }
  </script>
</BaseLayout>

<style>
  .dataset-detail {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 300px);
    gap: 1rem;
    align-items: start;
  }

  .dataset-main,
  .dataset-meta {
    border: none;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .dataset-main {
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .dataset-meta {
    padding: 0;
    position: sticky;
    top: 88px;
  }

  .dataset-kicker {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .dataset-description {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    max-width: var(--measure-reading);
  }

  .dataset-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0.55rem 0 0;
  }

  .dataset-tags a {
    padding: 0;
    background: transparent;
    color: var(--color-link);
    font-size: 0.82rem;
  }

  .dataset-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.8rem;
  }

  .dataset-actions a {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    padding: 0.32rem 0.52rem;
    background: var(--color-bg-elevated);
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .dataset-actions a:hover {
    text-decoration: none;
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
  }

  .dataset-tab-list {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.7rem;
  }

  .dataset-tab-trigger {
    border: 1px solid var(--color-border);
    border-radius: 0.34rem;
    background: var(--color-bg-elevated);
    color: var(--color-muted);
    padding: 0.24rem 0.5rem;
    font: inherit;
    font-size: 0.83rem;
    cursor: pointer;
  }

  .dataset-tab-trigger[aria-selected="true"],
  .dataset-tab-trigger.is-active {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
    background: color-mix(in srgb, var(--color-accent) 9%, var(--color-surface));
  }

  .dataset-tab-panel {
    display: grid;
    gap: 0.9rem;
  }

  .dataset-tab-panel :global(p),
  .dataset-tab-panel :global(ul),
  .dataset-tab-panel :global(ol),
  .dataset-tab-panel :global(blockquote),
  .dataset-tab-panel :global(dl) {
    max-width: var(--measure-reading);
  }

  .dataset-meta h2 {
    margin: 0 0 0.5rem;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .dataset-meta dl {
    margin: 0;
    display: grid;
    gap: 0.24rem;
  }

  .dataset-meta dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }

  .dataset-meta dd {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text);
    word-break: break-word;
  }

  .dataset-empty {
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 1040px) {
    .dataset-detail {
      grid-template-columns: 1fr;
    }

    .dataset-meta {
      position: static;
    }
  }
</style>
