---
import { getEntry } from "astro:content";
import MarkdownRenderer from "@components/MarkdownRenderer.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const about = await getEntry("pages", "about");
const { Content } = await about.render();

const team = [
	{ name: "Shubham Attri", role: "Applied Technology & Strategy", link: "mailto:shubham@phi9.space" },
	{ name: "Rudraksh", role: "Hardware & Robotics Engineering", link: null },
	{ name: "Raunak", role: "Mathematics & Algorithms", link: null },
];
---

<BaseLayout
	title={`${about.data.title} — phi9.space`}
	description={about.data.description}
	pageType="article"
	fullWidth={true}
>
  <!-- Hero -->
  <section class="about-hero">
    <div class="about-hero__bg"></div>
    <div class="about-hero__content container">
      <span class="eyebrow">About phi9.space</span>
      <h1>{about.data.heroSubtitle || about.data.title}</h1>
    </div>
  </section>

  <!-- Mission -->
  <section class="section">
    <div class="container">
      <div class="about-mission reveal">
        <div class="about-mission__image">
          <div class="about-mission__placeholder">
            <svg viewBox="0 0 200 200" fill="none" class="about-mission__icon">
              <circle cx="100" cy="100" r="80" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.2" />
              <circle cx="100" cy="100" r="50" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.35" />
              <circle cx="100" cy="100" r="20" fill="var(--color-accent)" opacity="0.15" />
              <path d="M100 20 L100 60 M100 140 L100 180 M20 100 L60 100 M140 100 L180 100" stroke="var(--color-accent)" stroke-width="1" opacity="0.25" />
            </svg>
          </div>
        </div>
        <div class="about-mission__text">
          <MarkdownRenderer Content={Content} raw={about.body} />
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section values-section">
    <div class="container">
      <h2 class="section-heading reveal">What we believe</h2>
      <div class="about-values reveal">
        <div class="about-value">
          <svg viewBox="0 0 40 40" class="about-value__icon"><polygon points="20,2 38,14 32,36 8,36 2,14" fill="none" stroke="var(--color-accent)" stroke-width="1.5"/></svg>
          <h3>Agency is universal</h3>
          <p>Intelligence transcends specific sensors or limbs. Our agents learn through understanding signals, not fixed inputs.</p>
        </div>
        <div class="about-value">
          <svg viewBox="0 0 40 40" class="about-value__icon"><circle cx="20" cy="20" r="16" fill="none" stroke="var(--color-accent)" stroke-width="1.5"/><circle cx="20" cy="20" r="6" fill="var(--color-accent)" opacity="0.3"/></svg>
          <h3>Open infrastructure</h3>
          <p>We leverage open-source, work with labs, and focus on post-training and deployment — surfing the wave of algorithmic progress.</p>
        </div>
        <div class="about-value">
          <svg viewBox="0 0 40 40" class="about-value__icon"><path d="M8 32 L32 8" stroke="var(--color-accent)" stroke-width="1.5"/><path d="M22 8 L32 8 L32 18" fill="none" stroke="var(--color-accent)" stroke-width="1.5"/></svg>
          <h3>Progress over perfection</h3>
          <p>Ship, learn, iterate. Physical agents are the path to resource abundance — systems that work in the real world.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading reveal">The team</h2>
      <p class="team-intro reveal">
        College roommates who've been building together since Ultrahuman.
        We've lived at the intersection of research and product.
      </p>
      <div class="team-table reveal">
        <div class="team-table__header">
          <span>Name</span>
          <span>Role</span>
          <span>Contact</span>
        </div>
        {team.map((m) => (
          <div class="team-table__row">
            <span class="team-table__name">{m.name}</span>
            <span class="team-table__role">{m.role}</span>
            <span class="team-table__contact">
              {m.link ? <a href={m.link}>Email</a> : <span class="team-table__muted">—</span>}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="about-cta reveal">
        <h2>Work with us</h2>
        <p>We're always looking for collaborators, partners, and people who want to build the future of physical AI.</p>
        <div class="about-cta__actions">
          <a href="mailto:research@phi9.space" class="btn btn-primary">Get in touch</a>
          <a href="https://discord.gg/4TaC3amBmx" class="btn btn-secondary" target="_blank" rel="noreferrer">Join Discord</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    position: relative;
    padding: clamp(7rem, 12vw, 10rem) 0 clamp(3rem, 6vw, 4rem);
    overflow: hidden;
  }

  .about-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
  }

  .about-hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
  }

  .about-hero__content h1 {
    max-width: 22ch;
    margin: 0;
  }

  /* Mission */
  .about-mission {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }

  .about-mission__placeholder {
    aspect-ratio: 1;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-mission__icon {
    width: 50%;
    height: 50%;
    animation: pulse-slow 4s ease-in-out infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }

  .about-mission__text {
    max-width: 60ch;
  }

  .about-mission__text :global(p) {
    line-height: 1.7;
  }

  .about-mission__text :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text);
  }

  @media (max-width: 800px) {
    .about-mission { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* Values */
  .section-heading {
    margin-bottom: 2rem;
  }

  .values-section {
    background: #f5f6f8;
  }

  .about-values {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2.5rem;
  }

  .about-value {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .about-value__icon {
    width: 2.25rem;
    height: 2.25rem;
  }

  .about-value h3 {
    margin: 0;
    font-size: 1.0625rem;
  }

  .about-value p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.55;
  }

  /* Team */
  .team-intro {
    color: var(--color-muted);
    max-width: 55ch;
    margin-bottom: 2rem;
  }

  .team-table {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .team-table__header {
    display: grid;
    grid-template-columns: 1fr 1.5fr 0.75fr;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    background: var(--color-bg-elevated);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .team-table__row {
    display: grid;
    grid-template-columns: 1fr 1.5fr 0.75fr;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    align-items: center;
    transition: background 0.15s ease;
  }

  .team-table__row:last-child { border-bottom: none; }
  .team-table__row:hover { background: var(--color-bg-elevated); }

  .team-table__name {
    font-family: var(--font-heading);
    font-weight: 500;
  }

  .team-table__role {
    color: var(--color-muted);
    font-size: 0.9375rem;
  }

  .team-table__contact a {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
  }

  .team-table__muted {
    color: var(--color-muted);
  }

  @media (max-width: 600px) {
    .team-table__header,
    .team-table__row {
      grid-template-columns: 1fr 1fr;
    }
    .team-table__header span:nth-child(3),
    .team-table__row span:nth-child(3) { display: none; }
  }

  /* CTA */
  .about-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: clamp(2rem, 5vw, 3rem) 0;
  }

  .about-cta h2 { margin: 0; }

  .about-cta p {
    color: var(--color-muted);
    max-width: 45ch;
    margin: 0;
  }

  .about-cta__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
</style>
