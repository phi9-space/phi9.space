---
import { getEntry } from "astro:content";
import MarkdownRenderer from "@components/MarkdownRenderer.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const about = await getEntry("pages", "about");
const { Content } = await about.render();
---

<BaseLayout
	title={`${about.data.title} — phi9.space`}
	description={about.data.description}
	pageType="article"
>
  <article>
    <p class="eyebrow">phi9.space</p>
    <h1>{about.data.title}</h1>
    {about.data.heroSubtitle && <p class="subtitle">{about.data.heroSubtitle}</p>}
    <MarkdownRenderer Content={Content} raw={about.body} />
  </article>
</BaseLayout>

<style>
  .eyebrow {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
  }

  .subtitle {
    margin-top: -0.3rem;
    color: var(--color-muted);
    max-width: 70ch;
  }
</style>
