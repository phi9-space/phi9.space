---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactCTA from "@components/ContactCTA.astro";
import DotGrid from "@components/visuals/DotGrid.astro";
import HalfCircle from "@components/visuals/HalfCircle.astro";
import InkRect from "@components/visuals/InkRect.astro";
import SignalCircle from "@components/visuals/SignalCircle.astro";
import VerticalBar from "@components/visuals/VerticalBar.astro";
---

<BaseLayout
	title="Lab — phi9.space"
	description="Lab overview, systems, and research infrastructure for phi9.space."
	fullWidth={true}
>
  <!-- Hero -->
  <section class="lab-hero">
    <div class="lab-hero__content container">
      <span class="eyebrow">Lab</span>
      <h1 class="lab-hero__title">The lab is where data becomes systems.</h1>
      <span class="rule" aria-hidden="true"></span>
      <p class="lab-hero__sub">
        Phi9 builds products, workflows, and infrastructure for physical AI. The lab is where
        capture rigs, training pipelines, evaluation systems, and the software that deploys a
        policy into the world all get stitched into one working stack.
      </p>
    </div>
  </section>

  <!-- Products -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading reveal">Featured systems</h2>
      <p class="section-copy reveal">
        The systems the lab runs on. Capture rigs, data products, and the research surfaces
        that make each of them reusable. Not background machinery — part of what phi9 is.
      </p>
      <div class="products-grid">
        <a href="/lab/mocap-rig" class="product-card reveal">
          <div class="product-card__image" aria-hidden="true">
            <div class="product-card__poster product-card__poster--rig">
              <div class="product-card__poster-circle">
                <SignalCircle size="clamp(4rem, 7vw, 6rem)" />
              </div>
              <div class="product-card__poster-rect">
                <InkRect
                  width="clamp(2rem, 4vw, 3rem)"
                  height="clamp(5rem, 9vw, 7rem)"
                />
              </div>
              <div class="product-card__poster-dots">
                <DotGrid rows={3} cols={5} spacing="0.35rem" dotSize="0.25rem" />
              </div>
            </div>
          </div>
          <div class="product-card__body">
            <span class="product-card__label">Capture system</span>
            <h3>MoCap Rig v1</h3>
            <p>
              Full-body motion, egocentric video, and structured task traces built for research
              reuse rather than one-off collection.
            </p>
            <span class="product-card__link">Learn more →</span>
          </div>
        </a>

        <div class="product-card product-card--coming reveal" style="transition-delay: 0.1s">
          <div class="product-card__image" aria-hidden="true">
            <div class="product-card__poster product-card__poster--catalog">
              <div class="product-card__poster-half">
                <HalfCircle
                  size="clamp(4rem, 7vw, 6rem)"
                  orientation="right"
                />
              </div>
              <div class="product-card__poster-bars">
                <VerticalBar
                  width="clamp(0.6rem, 1vw, 0.9rem)"
                  height="clamp(3rem, 5vw, 4rem)"
                  color="var(--color-text)"
                />
                <VerticalBar
                  width="clamp(0.6rem, 1vw, 0.9rem)"
                  height="clamp(4rem, 7vw, 5.5rem)"
                  color="var(--color-text)"
                />
                <VerticalBar
                  width="clamp(0.6rem, 1vw, 0.9rem)"
                  height="clamp(2.5rem, 4.5vw, 3.5rem)"
                />
              </div>
            </div>
          </div>
          <div class="product-card__body">
            <span class="product-card__label">Data product</span>
            <h3>Data Catalog</h3>
            <p>
              Structured outputs, metadata layers, and evaluation traces that keep demonstrations
              reusable across experiments.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section class="section how-section">
    <div class="container">
      <h2 class="section-heading reveal">Infrastructure stack</h2>
      <p class="section-copy reveal">
        Our stack spans capture, processing, annotation, post-training, and evaluation. Each layer
        exists to make the others more useful.
      </p>
      <div class="how-grid reveal">
        <div class="how-step">
          <span class="how-step__num">01</span>
          <h3>Capture</h3>
          <p>Multi-modal rigs that record motion, video, and task context together — not narrow lab demos.</p>
        </div>
        <div class="how-step">
          <span class="how-step__num">02</span>
          <h3>Processing</h3>
          <p>Segmentation, formatting, and synchronization that keep each demonstration usable after capture.</p>
        </div>
        <div class="how-step">
          <span class="how-step__num">03</span>
          <h3>Annotation &amp; retargeting</h3>
          <p>Metadata, skeletal retargeting, and augmentation that stretch scarce real-world behavior further.</p>
        </div>
        <div class="how-step">
          <span class="how-step__num">04</span>
          <h3>Training</h3>
          <p>Policy and post-training workflows that stay close to the structure of the captured data.</p>
        </div>
        <div class="how-step">
          <span class="how-step__num">05</span>
          <h3>Evaluation &amp; transfer</h3>
          <p>Benchmarks, failure analysis, and deployment feedback that make real-world performance visible.</p>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA
    eyebrow="Contact"
    headline="Working in physical AI?"
    body="The lab is one surface in a larger loop. Get in touch if you are working on data, research systems, or deployment infrastructure for physical intelligence."
    secondaryHref="/data"
    secondaryLabel="See the data"
  />
</BaseLayout>

<style>
  /* Hero */
  .lab-hero {
    position: relative;
    padding: clamp(7rem, 13vw, 11rem) 0 clamp(3rem, 6vw, 4.5rem);
  }

  .lab-hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin: 0 0 1.25rem;
  }

  .lab-hero__title {
    font-size: var(--type-display-lg);
    line-height: 0.98;
    letter-spacing: -0.04em;
    max-width: 18ch;
    margin: 0 0 1.25rem;
  }

  .lab-hero .rule {
    width: 12ch;
    margin: 0 0 1.5rem;
  }

  .lab-hero__sub {
    max-width: 58ch;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.55;
    font-size: clamp(1rem, 1.3vw, 1.15rem);
  }

  /* Section heading */
  .section-heading { margin-bottom: 2rem; }

  .section-copy {
    max-width: 46rem;
    margin: -0.75rem 0 2rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  /* Products */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    color: var(--color-text);
    transition: border-color 0.2s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }

  a.product-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .product-card__image {
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .product-card__poster {
    position: relative;
    aspect-ratio: 16/9;
    background: var(--color-surface);
    padding: clamp(1rem, 2vw, 1.75rem);
  }

  .product-card__poster-circle,
  .product-card__poster-rect,
  .product-card__poster-dots,
  .product-card__poster-half,
  .product-card__poster-bars {
    position: absolute;
  }

  .product-card__poster--rig .product-card__poster-circle {
    top: clamp(0.75rem, 1.5vw, 1.25rem);
    right: clamp(0.75rem, 2vw, 1.5rem);
  }

  .product-card__poster--rig .product-card__poster-rect {
    top: clamp(2.25rem, 5vw, 3.5rem);
    right: clamp(4.5rem, 9vw, 7rem);
  }

  .product-card__poster--rig .product-card__poster-dots {
    bottom: clamp(0.75rem, 1.5vw, 1.25rem);
    left: clamp(0.75rem, 2vw, 1.5rem);
  }

  .product-card__poster--catalog .product-card__poster-half {
    top: clamp(0.75rem, 2vw, 1.4rem);
    left: clamp(0.75rem, 2vw, 1.4rem);
  }

  .product-card__poster--catalog .product-card__poster-bars {
    bottom: clamp(0.75rem, 1.5vw, 1.25rem);
    right: clamp(0.75rem, 2vw, 1.5rem);
    display: flex;
    align-items: flex-end;
    gap: 0.35rem;
  }

  .product-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .product-card__label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    font-weight: 500;
  }

  .product-card__body h3 {
    margin: 0;
    font-size: 1.125rem;
  }

  .product-card__body p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .product-card__link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-top: 0.25rem;
  }

  .product-card--coming {
    opacity: 0.82;
  }

  /* How we work */
  .how-section {
    background: var(--color-surface);
  }

  .how-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .how-step {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .how-step__num {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .how-step h3 {
    margin: 0;
    font-size: 1.0625rem;
  }

  .how-step p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

</style>
