---
import { getEntry } from "astro:content";
import DocumentLayout from "@layouts/DocumentLayout.astro";

const page = await getEntry("pages", "mocap-rig");
if (!page) {
	throw new Error("Pages collection: entry 'mocap-rig' not found. Run `astro sync` and restart dev server.");
}
const { Content } = await page.render();
---

<DocumentLayout
	entry={page}
	Content={Content}
	eyebrow="Lab / Product"
	showContactCTA
	contactHeadline="Building capture systems for physical AI?"
	contactBody="If you are working on motion capture, multi-modal data collection, or training pipelines for physical AI, write to us."
	contactSecondaryHref="/data"
	contactSecondaryLabel="See the data"
/>
