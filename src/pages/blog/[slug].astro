---
import { getCollection } from "astro:content";
import legacySlugMap from "@generated/legacy-slug-map.json";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	const fromPosts = posts.map((post) => post.slug);
	const fromMap = Object.keys(legacySlugMap || {});
	const slugs = Array.from(new Set([...fromPosts, ...fromMap]));
	return slugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug || "";
const mappedSlug = legacySlugMap[slug] || slug;
const target = `/vault/${mappedSlug}/`;
Astro.response.headers.set("Location", target);
Astro.response.status = 308;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <title>Redirecting…</title>
    <link rel="canonical" href={target} />
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>.</p>
  </body>
</html>
