---
import { getEntry } from "astro:content";
import DocumentLayout from "@layouts/DocumentLayout.astro";

const page = await getEntry("pages", "data");
if (!page) {
	throw new Error("Pages collection: entry 'data' not found. Run `astro sync` and restart dev server.");
}
const { Content } = await page.render();
---

<DocumentLayout
	entry={page}
	Content={Content}
	eyebrow="Data"
	showContactCTA
	contactHeadline="Building data systems for physical AI?"
	contactBody="If you are working on collection, structured datasets, or research infrastructure for embodied systems, write to us."
	contactSecondaryHref="/lab"
	contactSecondaryLabel="See the lab"
/>
