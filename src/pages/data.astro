---
import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactCTA from "@components/ContactCTA.astro";
import BraillePulse from "@components/visuals/BraillePulse.astro";
import DataStreamRail from "@components/visuals/DataStreamRail.astro";
import DotGrid from "@components/visuals/DotGrid.astro";
import HalfCircle from "@components/visuals/HalfCircle.astro";
import InkRect from "@components/visuals/InkRect.astro";
import SignalCircle from "@components/visuals/SignalCircle.astro";
import VerticalBar from "@components/visuals/VerticalBar.astro";

const page = await getEntry("pages", "data");
if (!page) {
	throw new Error("Pages collection: entry 'data' not found. Run `astro sync` and restart dev server.");
}

const capabilities = [
	{
		label: "Highest-fidelity motion",
		desc: "120+ Hz full-body pose with body and hand trajectories. Calibrated per session, minimal drift.",
	},
	{
		label: "Real-time multi-modal sync",
		desc: "Every modality — motion, video, depth, IMU, tactile — aligned to within a millisecond at capture.",
	},
	{
		label: "Manipulative + locomotive",
		desc: "Fine-motor tool use and whole-body movement, captured on the same rig without a setup swap.",
	},
	{
		label: "Parent + subtask labels",
		desc: "Hierarchical demonstration structure — parent task, subtasks, intent, success, and failure.",
	},
	{
		label: "Pipeline-ready exports",
		desc: "Drop straight into pretraining, policy training, or world-model pipelines. Format-native, simulation-ready.",
	},
	{
		label: "Multi-view video",
		desc: "Ego-centric and wrist POV streams together — first-person context plus close-object detail.",
	},
	{
		label: "Depth",
		desc: "Stereo and time-of-flight streams where geometry carries information the RGB does not.",
	},
	{
		label: "IMU",
		desc: "Wrist and body inertial signals. Context, redundancy, and sub-motion detail the cameras miss.",
	},
	{
		label: "Tactile",
		desc: "Glove-level force feedback for contact, grasp, and manipulation states.",
	},
	{
		label: "Scene metadata",
		desc: "Object state, lighting, layout, and calibration quality — the full context around every capture.",
	},
	{
		label: "Retargeting-ready",
		desc: "Skeletal maps export cleanly to humanoids, robot arms, and simulated agents.",
	},
	{
		label: "Evaluation traces",
		desc: "Success cases, failure modes, and transfer results across setups and environments.",
	},
];

const stats = [
	{ value: "12+", label: "Modalities per capture" },
	{ value: "25+", label: "Environment types" },
	{ value: "3", label: "Training pipelines" },
];

const pipelines = [
	"Pretraining data",
	"Policy training data",
	"World-model data",
];

---

<BaseLayout
	fullWidth={true}
	title="Data — phi9.space"
	description={page.data.description}
	pageType="article"
>
	<section class="data-hero">
		<div class="container">
			<p class="data-hero__eyebrow">
				<BraillePulse class="data-hero__eyebrow-pulse" />
				Data
			</p>
			<h1 class="data-hero__title">
				Building the highest-fidelity sensorimotor dataset for physical intelligence.
			</h1>
			<span class="rule data-hero__rule" aria-hidden="true"></span>
			<p class="data-hero__dek">
				Multi-modal, real-time synced, and exportable straight into pretraining, policy,
				and world-model pipelines. Phi9 captures the full shape of human behavior —
				manipulative and locomotive, body and hand, intent and failure — at the fidelity
				training and evaluation actually need.
			</p>
			<ul class="data-hero__modalities">
				<li>Tactile force feedback</li>
				<li>Motion</li>
				<li>Vision</li>
				<li>Depth</li>
				<li>Wrist POV</li>
				<li>IMU</li>
			</ul>
		</div>
	</section>

	<DataStreamRail />

	<section class="section stats-section">
		<div class="container">
			<ul class="stats">
				{stats.map((stat) => (
					<li class="stat">
						<p class="stat__value">{stat.value}</p>
						<p class="stat__label">{stat.label}</p>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section class="section capabilities-section">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Capabilities</span>
				<h2>What every capture carries.</h2>
				<p>
					Twelve capabilities ship with every phi9 capture — not a menu to pick from. They
					are recorded together, timed to the millisecond, and structured so each one can
					feed a pretraining, policy, or world-model pipeline without the others being
					rebuilt.
				</p>
			</div>

			<div class="capabilities__grid">
				{capabilities.map((cap, idx) => (
					<article class="capability reveal">
						<div class="capability__glyph">
							{idx % 5 === 0 && <SignalCircle size="2.4rem" />}
							{idx % 5 === 1 && <InkRect width="2.4rem" height="1.8rem" />}
							{idx % 5 === 2 && <DotGrid rows={3} cols={4} spacing="0.3rem" dotSize="0.25rem" />}
							{idx % 5 === 3 && <HalfCircle size="2.4rem" orientation="right" />}
							{idx % 5 === 4 && <VerticalBar width="0.5rem" height="2rem" color="var(--color-text)" />}
						</div>
						<h3>{cap.label}</h3>
						<p>{cap.desc}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section pipelines-section">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Outputs</span>
				<h2>Three training pipelines, one capture.</h2>
				<p>
					The same demonstration feeds pretraining data for foundation work, policy training
					data for robot skills, and world-model data for simulation and planning.
				</p>
			</div>
			<ul class="pipelines__list">
				{pipelines.map((p, idx) => (
					<li class="pipeline">
						<span class="pipeline__num">{String(idx + 1).padStart(2, "0")}</span>
						<span class="pipeline__label">{p}</span>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section class="section custom-capture-section">
		<div class="container">
			<div class="custom-capture reveal">
				<span class="section-kicker">Custom capture</span>
				<h2 class="custom-capture__headline">Request data your research actually needs.</h2>
				<span class="rule" aria-hidden="true"></span>
				<p class="custom-capture__body">
					Your research should not stall while you build a data pipeline. Phi9 captures
					custom, private, proprietary datasets — scoped to your task, your environment,
					and your evaluation criteria. We run the rig, synchronize the modalities, label
					the demonstrations, and hand back pipeline-ready data.
				</p>

				<form
					class="request-form"
					name="data-request"
					method="POST"
					data-netlify="true"
					netlify-honeypot="bot-field"
					action="/?data-request=thanks"
				>
					<input type="hidden" name="form-name" value="data-request" />
					<p class="request-form__honeypot" hidden>
						<label>Do not fill this: <input name="bot-field" /></label>
					</p>

					<div class="request-form__row">
						<label class="request-form__field">
							<span>Email</span>
							<input type="email" name="email" required autocomplete="email" placeholder="you@lab.edu" />
						</label>
						<label class="request-form__field">
							<span>Affiliation</span>
							<input type="text" name="affiliation" placeholder="Lab, team, or company" />
						</label>
					</div>

					<label class="request-form__field">
						<span>Task or data you need</span>
						<textarea
							name="task"
							required
							rows="4"
							placeholder="What are you trying to train, evaluate, or simulate? Which environments, modalities, or demonstration types?"
						></textarea>
					</label>

					<div class="request-form__actions">
						<button type="submit" class="request-form__submit">Request data →</button>
						<a href="mailto:research@phi9.space?subject=Custom capture inquiry" class="request-form__mail">
							Or email research@phi9.space
						</a>
					</div>
				</form>
			</div>
		</div>
	</section>

	<ContactCTA
		eyebrow="Contact"
		headline="Building data systems for physical AI?"
		body="If you are working on collection, structured datasets, or research infrastructure for embodied systems, write to us."
		secondaryHref="/lab"
		secondaryLabel="See the lab"
	/>
</BaseLayout>

<style>
	.data-hero {
		padding: clamp(7rem, 13vw, 11rem) 0 clamp(2rem, 4vw, 3rem);
	}

	.data-hero__eyebrow {
		margin: 0 0 1.25rem;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-accent);
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}

	.data-hero__eyebrow-pulse {
		font-size: 0.95rem;
		line-height: 1;
	}

	.data-hero__title {
		font-size: var(--type-display-lg);
		line-height: 0.98;
		letter-spacing: -0.04em;
		max-width: 22ch;
		margin: 0 0 1.25rem;
		font-weight: 600;
	}

	.data-hero__rule {
		width: 12ch;
		margin: 0 0 1.5rem;
	}

	.data-hero__dek {
		max-width: 62ch;
		color: var(--color-muted);
		margin: 0 0 1.75rem;
		font-size: clamp(1rem, 1.4vw, 1.2rem);
		line-height: 1.55;
	}

	.data-hero__modalities {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.1rem;
		font-family: var(--font-mono);
		font-size: 0.82rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-text);
	}

	.data-hero__modalities li {
		display: inline-flex;
		align-items: center;
	}

	.data-hero__modalities li + li::before {
		content: "|";
		color: var(--color-muted);
		margin-right: 1.1rem;
		opacity: 0.6;
	}

	.stats-section {
		padding: clamp(2.5rem, 5vw, 4rem) 0;
	}

	.stats {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1rem, 3vw, 3rem);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		padding: clamp(1.5rem, 3vw, 2.25rem) 0;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.stat__value {
		margin: 0;
		font-family: var(--font-heading);
		font-size: clamp(2rem, 5vw, 3.75rem);
		line-height: 1;
		letter-spacing: -0.03em;
		font-weight: 600;
	}

	.stat__label {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.custom-capture-section {
		padding: clamp(3rem, 6vw, 5rem) 0;
		border-top: 1px solid var(--color-border);
	}

	.custom-capture {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		max-width: 720px;
	}

	.custom-capture .section-kicker {
		margin-bottom: 0.8rem;
	}

	.custom-capture__headline {
		font-family: var(--font-heading);
		font-size: var(--type-display-md);
		line-height: 1.02;
		letter-spacing: -0.035em;
		font-weight: 600;
		margin: 0 0 1.25rem;
		max-width: 16ch;
	}

	.custom-capture .rule {
		width: 10ch;
		margin: 0 0 1.5rem;
	}

	.custom-capture__body {
		margin: 0 0 1.75rem;
		color: var(--color-muted);
		max-width: 60ch;
		line-height: 1.6;
		font-size: clamp(1rem, 1.3vw, 1.12rem);
	}

	.custom-capture__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1.25rem;
	}

	.custom-capture__primary {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.55rem 1rem;
		background: var(--color-text);
		color: var(--color-bg);
		font-family: var(--font-mono);
		font-size: 0.82rem;
		letter-spacing: 0.05em;
		text-decoration: none;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.custom-capture__primary:hover {
		background: var(--color-accent);
		color: var(--color-text-inverse);
		text-decoration: none;
	}

	.custom-capture__secondary {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-accent);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.custom-capture__secondary:hover {
		color: var(--color-accent-hover);
		text-decoration: none;
	}

	.capabilities__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0;
		border-top: 1px solid var(--color-border);
		border-left: 1px solid var(--color-border);
	}

	.capability {
		padding: clamp(1.25rem, 2vw, 1.75rem);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		border-right: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		min-height: 11rem;
	}

	.capability__glyph {
		display: flex;
		align-items: center;
		min-height: 2.5rem;
	}

	.capability h3 {
		margin: 0;
		font-size: clamp(1.1rem, 1.6vw, 1.3rem);
		line-height: 1.2;
		font-weight: 600;
	}

	.capability p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.pipelines__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0;
		border-top: 1px solid var(--color-border);
	}

	.pipeline {
		padding: clamp(1.25rem, 2vw, 1.75rem);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		border-right: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		min-height: 7.5rem;
	}

	.pipeline:last-child {
		border-right: none;
	}

	.pipeline__num {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		color: var(--color-accent);
	}

	.pipeline__label {
		font-family: var(--font-heading);
		font-size: clamp(1.2rem, 1.8vw, 1.55rem);
		line-height: 1.15;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.request-form {
		margin-top: 0.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-width: 640px;
	}

	.request-form__honeypot {
		display: none;
	}

	.request-form__row {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.request-form__field {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.request-form__field span {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.request-form__field input,
	.request-form__field textarea {
		border: none;
		border-bottom: 1.5px solid var(--color-text);
		background: transparent;
		padding: 0.55rem 0;
		font-family: var(--font-body);
		font-size: 1.02rem;
		color: var(--color-text);
		outline: none;
	}

	.request-form__field textarea {
		min-height: 6.5rem;
		resize: vertical;
	}

	.request-form__field input::placeholder,
	.request-form__field textarea::placeholder {
		color: color-mix(in srgb, var(--color-muted) 65%, transparent);
	}

	.request-form__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1.25rem;
		margin-top: 0.4rem;
	}

	.request-form__submit {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.55rem 1.1rem;
		border: none;
		background: var(--color-text);
		color: var(--color-bg);
		font-family: var(--font-mono);
		font-size: 0.82rem;
		letter-spacing: 0.05em;
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.request-form__submit:hover {
		background: var(--color-accent);
		color: var(--color-text-inverse);
	}

	.request-form__mail {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		color: var(--color-muted);
		text-decoration: none;
	}

	.request-form__mail:hover {
		color: var(--color-accent);
		text-decoration: none;
	}

	@media (max-width: 560px) {
		.request-form__row {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 1100px) {
		.capabilities__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.stats {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
	}

	@media (max-width: 720px) {
		.capabilities__grid {
			grid-template-columns: 1fr;
		}

		.pipelines__list {
			grid-template-columns: 1fr;
		}

		.pipeline:last-child {
			border-right: 1px solid var(--color-border);
		}

		.data-hero__title {
			font-size: clamp(2rem, 8vw, 3rem);
		}
	}
</style>
