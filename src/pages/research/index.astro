---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsletterForm from "@components/NewsletterForm.astro";
import BraillePulse from "@components/visuals/BraillePulse.astro";

const posts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
	title="Research — phi9.space"
	description="Technical writeups, experiments, and findings from our work in physical AI, reinforcement learning, and robotics data."
	fullWidth={true}
>
  <!-- Hero -->
  <section class="research-hero">
    <div class="research-hero__content container">
      <span class="eyebrow"><BraillePulse class="eyebrow-pulse" /> Research</span>
      <h1 class="research-hero__title">Research notes, experiments, and technical evidence from the lab.</h1>
      <span class="rule" aria-hidden="true"></span>
      <p class="research-hero__sub">
        Active work, open questions, and figures from phi9. The log tracks the
        systems, experiments, and results that shape what we build next.
      </p>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map((post, i) => (
            <a href={`/research/${post.slug}/`} class="post-card reveal" style={`transition-delay: ${i * 0.08}s`}>
              <div class="post-card__image">
                {post.data.heroImage ? (
                  <img src={post.data.heroImage} alt="" loading="lazy" />
                ) : (
                  <div class="post-card__placeholder"></div>
                )}
              </div>
              <div class="post-card__body">
                <div class="post-card__meta">
                  {post.data.tags[0] && <span class="post-card__tag">{post.data.tags[0]}</span>}
                  <span>{new Date(post.data.pubDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
                </div>
                <h3 class="post-card__title">{post.data.title}</h3>
                <p class="post-card__desc">{post.data.description}</p>
                {post.data.tags.length > 1 && (
                  <div class="post-card__tags">
                    {post.data.tags.slice(1).map((tag) => (
                      <span class="post-card__tag-pill">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>No research posts published yet.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section newsletter-section">
    <div class="container">
      <div class="newsletter reveal">
        <h2>Research Dispatch</h2>
        <p class="newsletter__description">
          Technical writing on physical AI, datasets, and deployment. Published when there is something worth sharing.
        </p>
        <NewsletterForm />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .research-hero {
    position: relative;
    padding: clamp(7rem, 13vw, 11rem) 0 clamp(3rem, 6vw, 4.5rem);
  }

  .research-hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin: 0 0 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .eyebrow-pulse {
    font-size: 0.95rem;
    line-height: 1;
  }

  .research-hero__title {
    font-size: var(--type-display-lg);
    line-height: 0.98;
    letter-spacing: -0.04em;
    max-width: 22ch;
    margin: 0 0 1.25rem;
  }

  .research-hero .rule {
    width: 12ch;
    margin: 0 0 1.5rem;
  }

  .research-hero__sub {
    max-width: 58ch;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.55;
    font-size: clamp(1rem, 1.3vw, 1.15rem);
  }

  /* Posts grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(3rem, 5vw, 5rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (max-width: 700px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    color: var(--color-text);
  }

  .post-card:hover {
    text-decoration: none;
  }

  .post-card:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__image {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--gradient-hero);
  }

  .post-card__image img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .post-card__placeholder {
    aspect-ratio: 4/3;
    background: var(--gradient-hero);
  }

  .post-card__body {
    padding: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .post-card__meta {
    display: flex;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-card__tag {
    color: var(--color-accent);
  }

  .post-card__title {
    font-size: 1.125rem;
    margin: 0;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-card__desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .post-card__tag-pill {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  /* Empty state */
  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--color-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-state p { margin: 0; }

  /* Newsletter */
  .newsletter-section {
    padding: clamp(4rem, 8vw, 6rem) 0;
    border-top: 1px solid var(--color-border);
  }

  .newsletter {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter h2 {
    margin: 0 0 0.75rem;
    font-size: 1.5rem;
  }

  .newsletter__description {
    margin: 0 0 1.25rem;
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .newsletter__button {
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .newsletter__privacy {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>
