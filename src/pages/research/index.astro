---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
	title="Research — phi9.space"
	description="Technical writeups, experiments, and findings from our work in physical AI, reinforcement learning, and robotics data."
>
  <div class="page-flow">
    <section class="hero">
      <p class="section-kicker">Research</p>
      <h1>Research</h1>
      <p class="hero-description">
        Technical writeups, experiments, and findings from our work in physical AI,
        reinforcement learning, and robotics data.
      </p>
    </section>

    {posts.length > 0 ? (
      <section class="post-list">
        {posts.map((post) => (
          <article class="post-entry">
            <div class="post-meta">
              <span class="post-date">{post.data.pubDate.toLocaleDateString()}</span>
            </div>
            <h3>
              <a href={`/research/${post.slug}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </section>
    ) : (
      <p class="empty-hint">No research posts published yet.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-flow {
    display: grid;
    gap: clamp(1.6rem, 3vw, 2.3rem);
  }

  .hero {
    display: grid;
    gap: 0.5rem;
  }

  .section-kicker {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero h1 {
    margin: 0;
  }

  .hero-description {
    margin: 0;
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-entry {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-entry:last-child {
    border-bottom: none;
  }

  .post-meta {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-author {
    color: var(--color-accent);
    font-weight: 600;
  }

  .post-date {
    color: var(--color-muted);
  }

  .post-entry h3 {
    margin: 0 0 0.35rem;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .post-entry h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-entry h3 a:hover {
    color: var(--color-accent);
  }

  .post-entry p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .tag {
    font-size: 0.72rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .empty-hint {
    margin: 0;
    color: var(--color-muted);
    padding: 2rem;
    text-align: center;
    background: var(--color-surface);
    border-radius: 0.5rem;
    border: 1px dashed var(--color-border);
  }
</style>
