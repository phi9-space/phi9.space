---
import manifest from "@generated/vault-manifest.json";
import VaultLayout from "@layouts/VaultLayout.astro";

const notes = (manifest.nodes || [])
	.filter((node) => node.type === "note")
	.slice()
	.sort((a, b) => {
		const aDate = a.updated ? new Date(a.updated) : new Date(0);
		const bDate = b.updated ? new Date(b.updated) : new Date(0);
		return bDate.valueOf() - aDate.valueOf();
	});

// Group notes by category
const notesByCategory = notes.reduce((acc, note) => {
  const category = note.category || 'uncategorized';
  if (!acc[category]) acc[category] = [];
  acc[category].push(note);
  return acc;
}, {});

const featuredNotes = notes.filter((note) => note.featured);
const recentNotes = notes.slice(0, 6);
---

<VaultLayout
	title="Research — phi9.space"
	description="Research notes, technical documentation, and insights on robotics data, motion capture, and robot learning."
>
  <section class="hero">
    <p class="section-kicker">Research</p>
    <h1>Research & Documentation</h1>
    <p class="hero-description">
      Technical insights, methodologies, and findings from our work in robotics training data, 
      motion capture systems, and embodied AI.
    </p>
  </section>

  {featuredNotes.length > 0 && (
    <section class="featured-section">
      <h2>Featured Research</h2>
      <div class="featured-grid">
        {featuredNotes.map((note) => (
          <article class="featured-card">
            <div class="featured-meta">
              <span class="featured-badge">★ Featured</span>
              <span class="featured-category">{note.category}</span>
            </div>
            <h3>
              <a href={note.url}>{note.title}</a>
            </h3>
            <p>{note.excerpt}</p>
            <div class="featured-footer">
              {note.updated && <span>Updated {new Date(note.updated).toLocaleDateString()}</span>}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="recent-section">
    <div class="section-header">
      <h2>Recent Notes</h2>
      <span class="count">{notes.length} total</span>
    </div>
    
    {recentNotes.length > 0 ? (
      <div class="recent-list">
        {recentNotes.map((note) => (
          <article class="recent-entry">
            <div class="recent-meta">
              <span class="recent-category">{note.category}</span>
              {note.updated && <span class="recent-date">{new Date(note.updated).toLocaleDateString()}</span>}
            </div>
            <h3>
              <a href={note.url}>{note.title}</a>
            </h3>
            <p>{note.excerpt}</p>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-hint">
        No research notes published yet. Start with the publishing workflow guide at
        <a href="/lab/publishing">/lab/publishing</a>.
      </p>
    )}
  </section>

  {Object.keys(notesByCategory).length > 1 && (
    <section class="categories-section">
      <h2>Browse by Category</h2>
      <div class="category-grid">
        {Object.entries(notesByCategory).map(([category, categoryNotes]) => (
          <div class="category-card">
            <h3>{category}</h3>
            <span class="category-count">{categoryNotes.length} note{categoryNotes.length !== 1 ? 's' : ''}</span>
            <ul>
              {categoryNotes.slice(0, 3).map((note) => (
                <li><a href={note.url}>{note.title}</a></li>
              ))}
              {categoryNotes.length > 3 && (
                <li class="more">+{categoryNotes.length - 3} more</li>
              )}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="tools-section">
    <h2>Research Tools</h2>
    <div class="tools-grid">
      <a href="/vault/" class="tool-card">
        <h3>📚 Vault Browser</h3>
        <p>Browse all notes with full backlinks and graph view.</p>
      </a>
      <a href="/datasets/" class="tool-card">
        <h3>📊 Dataset Catalog</h3>
        <p>Explore published datasets and model cards.</p>
      </a>
    </div>
  </section>
</VaultLayout>

<style>
  .hero {
    margin-bottom: 2rem;
  }

  .section-kicker {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero h1 {
    margin: 0.5rem 0;
    font-size: 2rem;
    line-height: 1.2;
  }

  .hero-description {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 60ch;
    line-height: 1.6;
  }

  .featured-section {
    margin-bottom: 2.5rem;
  }

  .featured-section h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }

  .featured-card {
    padding: 1.25rem;
    background: linear-gradient(135deg, var(--color-surface) 0%, color-mix(in srgb, var(--color-accent) 5%, var(--color-surface)) 100%);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 0.75rem;
  }

  .featured-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .featured-badge {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .featured-category {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }

  .featured-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .featured-card h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .featured-card h3 a:hover {
    color: var(--color-accent);
  }

  .featured-card p {
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .featured-footer {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .recent-section {
    margin-bottom: 2.5rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .count {
    font-size: 0.85rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .recent-entry {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .recent-entry:last-child {
    border-bottom: none;
  }

  .recent-meta {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .recent-category {
    color: var(--color-accent);
    font-weight: 600;
  }

  .recent-date {
    color: var(--color-muted);
  }

  .recent-entry h3 {
    margin: 0 0 0.35rem;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .recent-entry h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .recent-entry h3 a:hover {
    color: var(--color-accent);
  }

  .recent-entry p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .empty-hint {
    margin: 0;
    color: var(--color-muted);
    padding: 2rem;
    text-align: center;
    background: var(--color-surface);
    border-radius: 0.5rem;
    border: 1px dashed var(--color-border);
  }

  .categories-section {
    margin-bottom: 2.5rem;
  }

  .categories-section h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .category-card {
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .category-card h3 {
    margin: 0 0 0.25rem;
    font-size: 1rem;
    text-transform: capitalize;
  }

  .category-count {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .category-card ul {
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
  }

  .category-card li {
    margin: 0.35rem 0;
    font-size: 0.9rem;
  }

  .category-card li a {
    color: var(--color-text);
    text-decoration: none;
  }

  .category-card li a:hover {
    color: var(--color-accent);
  }

  .category-card li.more {
    color: var(--color-muted);
    font-size: 0.8rem;
  }

  .tools-section h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .tool-card {
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.15s ease;
  }

  .tool-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .tool-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .tool-card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
</style>