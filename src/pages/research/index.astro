---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
	title="Research — phi9.space"
	description="Technical writeups, experiments, and findings from our work in physical AI, reinforcement learning, and robotics data."
	fullWidth={true}
>
  <!-- Hero -->
  <section class="research-hero">
    <div class="research-hero__bg"></div>
    <div class="research-hero__content container">
      <span class="eyebrow">Research</span>
      <h1>From the research log</h1>
      <p class="research-hero__sub">
        Technical writeups, experiments, and findings from our work
        in physical AI, reinforcement learning, and robotics data.
      </p>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map((post, i) => (
            <a href={`/research/${post.slug}/`} class="post-card reveal" style={`transition-delay: ${i * 0.08}s`}>
              <div class="post-card__image">
                <div class="post-card__placeholder"></div>
              </div>
              <div class="post-card__body">
                <div class="post-card__meta">
                  {post.data.tags[0] && <span class="post-card__tag">{post.data.tags[0]}</span>}
                  <span>{new Date(post.data.pubDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
                </div>
                <h3 class="post-card__title">{post.data.title}</h3>
                <p class="post-card__desc">{post.data.description}</p>
                {post.data.tags.length > 1 && (
                  <div class="post-card__tags">
                    {post.data.tags.slice(1).map((tag) => (
                      <span class="post-card__tag-pill">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>No research posts published yet.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter / CTA -->
  <section class="section subscribe-section">
    <div class="container">
      <div class="subscribe reveal">
        <h2>Stay in the loop</h2>
        <p>Follow our research through RSS or join the Discord for discussion.</p>
        <div class="subscribe__actions">
          <a href="/rss.xml" class="btn btn-primary">Subscribe via RSS</a>
          <a href="https://discord.gg/4TaC3amBmx" class="btn btn-secondary" target="_blank" rel="noreferrer">Join Discord</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .research-hero {
    position: relative;
    padding: clamp(7rem, 12vw, 10rem) 0 clamp(3rem, 6vw, 4rem);
    overflow: hidden;
  }

  .research-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
  }

  .research-hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
  }

  .research-hero__content h1 {
    max-width: 20ch;
    margin: 0;
  }

  .research-hero__sub {
    max-width: 55ch;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* Posts grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(3rem, 5vw, 5rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (max-width: 700px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    color: var(--color-text);
  }

  .post-card:hover {
    text-decoration: none;
  }

  .post-card:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__placeholder {
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, #e2e5eb 0%, rgba(232, 85, 58, 0.06) 100%);
    border-radius: var(--radius-md);
  }

  .post-card__body {
    padding: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .post-card__meta {
    display: flex;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-card__tag {
    color: var(--color-accent);
  }

  .post-card__title {
    font-size: 1.125rem;
    margin: 0;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-card__desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .post-card__tag-pill {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  /* Empty state */
  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--color-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-state p { margin: 0; }

  /* Subscribe */
  .subscribe-section {
    background: #f5f6f8;
  }

  .subscribe {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .subscribe h2 { margin: 0; }

  .subscribe p {
    color: var(--color-muted);
    max-width: 40ch;
    margin: 0;
  }

  .subscribe__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
</style>
