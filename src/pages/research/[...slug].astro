---
import { getCollection } from "astro:content";
import LongformArticleShell from "@components/LongformArticleShell.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatLongDate, getReadingTime } from "@lib/site";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts
		.filter((post) => !post.data.draft)
		.map((post) => ({
			params: { slug: post.slug },
			props: post,
		}));
}

const post = Astro.props;
const { Content } = await post.render();

const allPosts = (await getCollection("blog"))
	.filter((p) => !p.data.draft && p.slug !== post.slug)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
const updatedLabel = post.data.updatedDate ? formatLongDate(post.data.updatedDate) : null;
const shareUrl = new URL(`/research/${post.slug}/`, Astro.site).toString();
---

<BaseLayout
	title={`${post.data.title} — phi9.space`}
	description={post.data.description}
	pageType="article"
	fullWidth={true}
>
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" />

  <LongformArticleShell
    title={post.data.title}
    dek={post.data.description}
    leadTag={post.data.tags[0] ?? "Research"}
    readingTime={getReadingTime(post.body)}
    publishedLabel={formatLongDate(post.data.pubDate)}
    updatedLabel={updatedLabel}
    authorLabel={post.data.author ?? "Phi9"}
    shareUrl={shareUrl}
  >
    {post.data.heroImage && <img slot="hero" src={post.data.heroImage} alt="" loading="lazy" />}
    <Content />
  </LongformArticleShell>

  <!-- Recent articles -->
  {allPosts.length > 0 && (
    <section class="recent">
      <div class="container">
        <div class="recent__header">
          <h2>Recent articles</h2>
          <a href="/research" class="recent__link">View all articles</a>
        </div>
        <div class="recent__grid">
          {allPosts.map((p) => (
            <a href={`/research/${p.slug}/`} class="recent__card">
              <div class="recent__image">
                {p.data.heroImage ? (
                  <img src={p.data.heroImage} alt="" loading="lazy" />
                ) : (
                  <div class="recent__image-placeholder"></div>
                )}
              </div>
              <h3>{p.data.title}</h3>
              <span class="recent__meta">
                {p.data.tags[0] && <span>{p.data.tags[0]}</span>}
                <span>·</span>
                <span>{getReadingTime(p.body)} min</span>
              </span>
              <p>{p.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ── Recent articles ── */
  .recent {
    background: var(--color-surface);
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .recent__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }

  .recent__header h2 {
    margin: 0;
  }

  .recent__link {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: underline;
  }

  .recent__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .recent__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--color-text);
  }

  .recent__card:hover {
    text-decoration: none;
  }

  .recent__card:hover h3 {
    color: var(--color-accent);
  }

  .recent__image {
    width: 100%;
    aspect-ratio: 4/3;
    margin-bottom: 0.25rem;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--gradient-hero);
  }

  .recent__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recent__image-placeholder {
    width: 100%;
    height: 100%;
    background: var(--gradient-hero);
  }

  .recent__card h3 {
    font-size: 1.0625rem;
    margin: 0;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .recent__meta {
    display: flex;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  .recent__card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 800px) {
    .recent__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
