---
import { getEntry } from "astro:content";
import DocumentLayout from "@layouts/DocumentLayout.astro";

const page = await getEntry("pages", "privacy");
if (!page) {
	throw new Error("Pages collection: entry 'privacy' not found. Run `astro sync` and restart dev server.");
}
const { Content } = await page.render();
---

<DocumentLayout entry={page} Content={Content} eyebrow="Legal" />
