---
import { getEntry } from "astro:content";
import DocumentLayout from "@layouts/DocumentLayout.astro";

const page = await getEntry("pages", "about");
if (!page) {
	throw new Error("Pages collection: entry 'about' not found. Run `astro sync` and restart dev server.");
}
const { Content } = await page.render();
---

<DocumentLayout
	entry={page}
	Content={Content}
	eyebrow="About"
	showContactCTA
	contactHeadline="Want to work with phi9?"
	contactBody="Phi9 builds physical AI systems end-to-end. If there is overlap with what you are building, write to us."
	contactSecondaryHref="/manifesto"
	contactSecondaryLabel="Read the manifesto"
/>
