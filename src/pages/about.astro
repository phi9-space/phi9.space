---
import { getEntry } from "astro:content";
import DocumentLayout from "@layouts/DocumentLayout.astro";

const page = await getEntry("pages", "about");
const { Content } = await page.render();
---

<DocumentLayout
	entry={page}
	Content={Content}
	eyebrow="About"
	showContactCTA
	contactHeadline="Want to work with phi9?"
	contactBody="We are a small team building physical AI systems end-to-end. If there is overlap with what you are building, write to us."
	contactSecondaryHref="/manifesto"
	contactSecondaryLabel="Read the manifesto"
/>
