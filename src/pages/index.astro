---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactCTA from "@components/ContactCTA.astro";
import BraillePulse from "@components/visuals/BraillePulse.astro";
import DataStreamRail from "@components/visuals/DataStreamRail.astro";
import DotGrid from "@components/visuals/DotGrid.astro";
import HalfCircle from "@components/visuals/HalfCircle.astro";
import InkRect from "@components/visuals/InkRect.astro";
import MotionTrace from "@components/visuals/MotionTrace.astro";
import MultiplyFork from "@components/visuals/MultiplyFork.astro";
import BenchmarkBars from "@components/visuals/BenchmarkBars.astro";
import SignalCircle from "@components/visuals/SignalCircle.astro";
import TrainWaveform from "@components/visuals/TrainWaveform.astro";
import VerticalBar from "@components/visuals/VerticalBar.astro";
import { formatLongDate, getReadingTime } from "@lib/site";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const featuredPost = latestPosts[0] ?? null;
const secondaryPosts = featuredPost ? latestPosts.slice(1, 3) : latestPosts.slice(0, 2);

const structuredData = {
	"@context": "https://schema.org",
	"@type": "Organization",
	name: "phi9.space",
	url: "https://phi9.space",
	description: "Physical AI research, data systems, and deployable intelligence.",
};

const openProblems = [
	{
		title: "Data that carries intent, not just observation.",
		desc: "Most pipelines record visible motion but lose the task underneath it. We are working on capture that preserves action, context, and what the body was trying to achieve.",
	},
	{
		title: "Physical data is expensive.",
		desc: "You cannot scrape physical behavior. Every demonstration needs a rig, a subject, a calibration, and a clean task. The work is making each capture travel further without losing signal.",
	},
	{
		title: "Benchmarks that predict real-world performance.",
		desc: "A benchmark score means little if a policy falls apart on an unscripted task. We care about evaluation that predicts transfer, failure, and what survives outside the benchmark.",
	},
	{
		title: "One loop, not three stages.",
		desc: "Capture, training, and evaluation still get treated as separate departments. We are trying to wire them into one visible loop so progress does not disappear between stages.",
	},
];

const methodSystems = [
	{
		title: "Capture surfaces",
		desc: "Rigs, sync, task framing, and sensor traces that start with the real world instead of a benchmark-only abstraction.",
	},
	{
		title: "Data structure",
		desc: "Labels, schemas, exports, and task boundaries that keep demonstrations reusable across research, training, and downstream tooling.",
	},
	{
		title: "Training systems",
		desc: "Retargeting, augmentation, and policy pipelines that stretch scarce behavior while preserving intent, motion, and context.",
	},
	{
		title: "Evaluation layer",
		desc: "Benchmark fragments, transfer tests, and failure traces that keep the loop honest about what actually generalizes.",
	},
];

const stats = [
	{ value: "4", label: "Loop stages" },
	{ value: "12+", label: "Modalities per capture" },
	{ value: "25+", label: "Environment types" },
];
---

<BaseLayout
	fullWidth={true}
	structuredData={structuredData}
	title="phi9.space"
	description="Physical AI research, data systems, and deployable intelligence."
>
	<section class="home-hero">
		<div class="container">
			<div class="home-hero__grid">
				<div class="home-hero__content reveal">
					<p class="home-hero__eyebrow">
						<BraillePulse class="home-hero__eyebrow-pulse" />
						Phi9 — physical AI lab
					</p>
					<h1 class="display-xl">
						Physical AI research, data systems, and deployable intelligence.
					</h1>
					<span class="rule" aria-hidden="true"></span>
					<p class="home-hero__copy">
						Phi9 captures real-world behavior, structures it for training, and evaluates
						what actually transfers — so research can become usable capability.
					</p>
					<div class="home-hero__actions">
						<a href="/lab" class="btn btn-primary">Explore the Lab</a>
						<a href="/data" class="btn btn-secondary">See the Data</a>
					</div>
				</div>

				<div class="home-hero__poster reveal" aria-hidden="true">
					<div class="home-hero__poster-circle">
						<SignalCircle size="clamp(12rem, 26vw, 22rem)" />
					</div>
					<div class="home-hero__poster-rect">
						<InkRect
							width="clamp(5rem, 10vw, 8.5rem)"
							height="clamp(10rem, 22vw, 19rem)"
						/>
					</div>
					<div class="home-hero__poster-half">
						<HalfCircle
							size="clamp(8rem, 18vw, 15rem)"
							orientation="left"
						/>
					</div>
					<div class="home-hero__poster-dots">
						<DotGrid rows={6} cols={8} spacing="0.55rem" dotSize="0.3rem" />
					</div>
				</div>
			</div>
		</div>
	</section>

	<DataStreamRail />

	<section class="section capability-loop">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">The loop</span>
				<h2>From capture to evaluation, the physical AI loop.</h2>
				<p>
					One loop. Four stages. The work is turning real-world behavior into signal,
					training against it, and measuring what survives contact with reality.
				</p>
			</div>

			<div class="capability-loop__grid">
				<article class="loop-step reveal">
					<div class="loop-step__glyph">
						<MotionTrace width="2.8rem" height="2.1rem" />
					</div>
					<span class="loop-step__num">001</span>
					<h3>Capture</h3>
					<p>
						Capture real-world demonstrations with synchronized motion, video, and
						structured task data. Start from real signal: task context, traces, and motion
						that can be used again.
					</p>
				</article>

				<article class="loop-step reveal">
					<div class="loop-step__glyph">
						<MultiplyFork width="2.7rem" height="2rem" />
					</div>
					<span class="loop-step__num">002</span>
					<h3>Multiply</h3>
					<p>
						Multiply scarce data through retargeting, simulation, augmentation, and
						better structure. Stretch each capture further without letting intent or task
						definition drift away.
					</p>
				</article>

				<article class="loop-step reveal">
					<div class="loop-step__glyph">
						<TrainWaveform width="2.8rem" height="2.1rem" />
					</div>
					<span class="loop-step__num">003</span>
					<h3>Train</h3>
					<p>
						Train policies and research systems on data that preserves intent, motion,
						and context. The point is not isolated models; it is a training layer that stays
						close to reality.
					</p>
				</article>

				<article class="loop-step reveal">
					<div class="loop-step__glyph">
						<BenchmarkBars width="2.4rem" height="2rem" />
					</div>
					<span class="loop-step__num">004</span>
					<h3>Evaluate</h3>
					<p>
						Evaluate what generalizes through benchmarks, failure analysis, and transfer
						tests. Treat deployment feedback and failure traces as part of the same loop.
					</p>
				</article>
			</div>
		</div>
	</section>

	<section class="section stats-section">
		<div class="container">
			<ul class="stats">
				{stats.map((stat) => (
					<li class="stat reveal">
						<p class="stat__value">{stat.value}</p>
						<p class="stat__label">{stat.label}</p>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section class="section featured-system">
		<div class="container">
			<div class="featured-system__grid">
				<div class="featured-system__panel reveal" aria-hidden="true">
					<span class="rule rule--accent featured-system__rule"></span>
					<p class="featured-system__eyebrow">MoCap Rig v1</p>

					<ul class="featured-system__rails">
						<li class="featured-system__rail">
							<div class="featured-system__rail-shape">
								<SignalCircle size="3.25rem" />
							</div>
							<div class="featured-system__rail-copy">
								<span>capture</span>
								<p>Full-body motion and first-person video, timed and labeled by task.</p>
							</div>
						</li>
						<li class="featured-system__rail">
							<div class="featured-system__rail-shape">
								<InkRect width="3.25rem" height="2.25rem" />
							</div>
							<div class="featured-system__rail-copy">
								<span>quality</span>
								<p>Aligned multimodal streams, validated against benchmarks.</p>
							</div>
						</li>
						<li class="featured-system__rail">
							<div class="featured-system__rail-shape">
								<DotGrid rows={4} cols={6} spacing="0.3rem" dotSize="0.22rem" />
							</div>
							<div class="featured-system__rail-copy">
								<span>output</span>
								<p>Research-ready demonstrations for training and evaluation loops.</p>
							</div>
						</li>
					</ul>
				</div>

				<div class="featured-system__content reveal">
					<span class="section-kicker">Featured system</span>
					<h2>The capture system behind the loop.</h2>
					<p>
						The Phi9 MoCap Rig records full-body motion and first-person video together,
						timed and labeled by task. The output is reusable training data instead of one-off
						recordings, so the same demonstration can move through training,
						fine-tuning, and deployment.
					</p>
					<a href="/data" class="featured-system__link">See the Data</a>
				</div>
			</div>
		</div>
	</section>

	<section class="section open-problems">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Research questions</span>
				<h2>The bottlenecks we are actively working through.</h2>
				<p>
					These are not abstract themes. They are the constraints shaping the systems,
					experiments, and artifacts we are building now.
				</p>
			</div>

			<ol class="open-problems__list">
				{
					openProblems.map((problem, idx) => (
						<li class="problem-row reveal">
							<span class="problem-row__num">{String(idx + 1).padStart(2, "0")}</span>
							<div class="problem-row__copy">
								<h3>{problem.title}</h3>
								<p>{problem.desc}</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</section>

	<section class="section research-proof">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Research</span>
				<h2>Projects, notes, and technical progress from the lab.</h2>
				<p>
					Open work from the loop: systems, experiments, and technical questions published as
					they evolve.
				</p>
			</div>

			<div class="research-proof__grid">
				{
					featuredPost ? (
						<a href={`/research/${featuredPost.slug}`} class="research-proof__featured reveal">
							<div class="research-proof__media">
								{
									featuredPost.data.heroImage ? (
										<img
											src={featuredPost.data.heroImage}
											alt={featuredPost.data.title}
											loading="lazy"
										/>
									) : (
										<div class="research-proof__placeholder">
											<span class="research-proof__placeholder-rule"></span>
											<p>Featured research item</p>
										</div>
									)
								}
							</div>
							<div class="research-proof__meta">
								{featuredPost.data.tags[0] && <span>{featuredPost.data.tags[0]}</span>}
								<time datetime={featuredPost.data.pubDate.toISOString()}>
									{formatLongDate(featuredPost.data.pubDate)}
								</time>
								<span>{getReadingTime(featuredPost.body)} min</span>
							</div>
							<h3>{featuredPost.data.title}</h3>
							<p>{featuredPost.data.description}</p>
						</a>
					) : (
						<div class="research-proof__featured reveal">
							<div class="research-proof__placeholder research-proof__placeholder--featured">
								<span class="research-proof__placeholder-rule"></span>
								<p>Featured research item</p>
							</div>
							<div class="research-proof__meta">
								<span>Research</span>
								<span>Archive feeling</span>
							</div>
							<h3>Projects, notes, and technical progress from the lab.</h3>
							<p>Use dates, tags, figures, and experiments to keep the archive active.</p>
						</div>
					)
				}

				<div class="research-proof__secondary">
					{
						secondaryPosts.length > 0 ? (
							secondaryPosts.map((post) => (
								<a href={`/research/${post.slug}`} class="research-proof__secondary-item reveal">
									<div class="research-proof__secondary-copy">
										<div class="research-proof__meta">
											{post.data.tags[0] && <span>{post.data.tags[0]}</span>}
											<time datetime={post.data.pubDate.toISOString()}>
												{formatLongDate(post.data.pubDate)}
											</time>
										</div>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
									</div>
									<div class="research-proof__secondary-thumb">
										{
											post.data.heroImage ? (
												<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
											) : (
												<div class="research-proof__placeholder research-proof__placeholder--thumb">
													<span class="research-proof__placeholder-rule"></span>
												</div>
											)
										}
									</div>
								</a>
							))
						) : (
							<>
								<div class="research-proof__secondary-item reveal">
									<div class="research-proof__secondary-copy">
										<div class="research-proof__meta">
											<span>Research</span>
											<span>Technical crop</span>
										</div>
										<h3>Secondary item 01 / figure crop</h3>
										<p>Use dates, tags, and reading time in mono. Research should feel active.</p>
									</div>
									<div class="research-proof__placeholder research-proof__placeholder--thumb">
										<span class="research-proof__placeholder-rule"></span>
									</div>
								</div>
								<div class="research-proof__secondary-item reveal">
									<div class="research-proof__secondary-copy">
										<div class="research-proof__meta">
											<span>Research</span>
											<span>Notebook fragment</span>
										</div>
										<h3>Secondary item 02 / notebook fragment</h3>
										<p>Use a figure, fragment, or technical note to extend the story.</p>
									</div>
									<div class="research-proof__placeholder research-proof__placeholder--thumb">
										<span class="research-proof__placeholder-rule"></span>
									</div>
								</div>
							</>
						)
					}
				</div>
			</div>
		</div>
	</section>

	<section class="section methods">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Methods</span>
				<h2>The concrete systems we are building around the loop.</h2>
				<p>
					Methods should feel like work, not philosophy. These are the concrete layers we are
					building now so demonstration, training, and deployment stay connected.
				</p>
			</div>

			<div class="methods__rows">
				{
					methodSystems.map((item, idx) => (
						<div class="method-row reveal">
							<div class="method-row__header">
								<div class="method-row__glyph" aria-hidden="true">
									{idx === 0 && <MotionTrace width="2.6rem" height="1.9rem" />}
									{idx === 1 && <InkRect width="2.1rem" height="1.5rem" color="var(--color-text)" />}
									{idx === 2 && <TrainWaveform width="2.6rem" height="1.9rem" />}
									{idx === 3 && <BenchmarkBars width="2.2rem" height="1.9rem" />}
								</div>
								<h3>{item.title}</h3>
							</div>
							<p>{item.desc}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<ContactCTA
		eyebrow="Contact"
		headline="Building in physical AI?"
		body="If you are working on data, research systems, or deployment infrastructure for physical intelligence, write to us."
		secondaryHref="/manifesto"
		secondaryLabel="Read the manifesto"
	/>
</BaseLayout>

<style>
	.home-hero {
		background: var(--gradient-hero);
		padding: clamp(7rem, 12vw, 10rem) 0 clamp(3.5rem, 6vw, 5rem);
	}

	.home-hero__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(280px, 1fr);
		gap: clamp(2rem, 4vw, 4rem);
		align-items: start;
	}

	.featured-system__grid,
	.research-proof__grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
		gap: clamp(2rem, 4vw, 3.5rem);
		align-items: start;
	}

	.home-hero__content {
		padding-top: clamp(0.5rem, 3vw, 1.25rem);
	}

	.home-hero__eyebrow {
		margin: 0 0 1.25rem;
		font-family: var(--font-mono);
		font-size: clamp(0.78rem, 1.1vw, 0.9rem);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}

	.home-hero__eyebrow-pulse {
		font-size: 0.95rem;
		line-height: 1;
	}

	.home-hero__content .display-xl {
		margin: 0 0 1.25rem;
		max-width: 18ch;
	}

	.home-hero__content .rule {
		margin: 0 0 1.5rem;
		width: 12ch;
	}

	.home-hero__copy,
	.section-heading p,
	.featured-system__content p,
	.problem-row__copy p,
	.method-row p,
	.research-proof__featured p,
	.research-proof__secondary-item p {
		color: var(--color-muted);
		max-width: 62ch;
	}

	.home-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.75rem;
	}

	.section-kicker {
		display: inline-block;
		margin-bottom: 0.8rem;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.section-kicker--inverse {
		color: color-mix(in srgb, var(--color-text-inverse) 82%, var(--color-accent) 18%);
	}

	.section-heading {
		display: grid;
		gap: 0.6rem;
		margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
		max-width: 50rem;
	}

	.research-proof__featured,
	.research-proof__secondary-item {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xl);
		background: color-mix(in srgb, var(--color-bg) 80%, var(--color-surface) 20%);
	}

	.research-proof__placeholder-rule {
		display: block;
		width: 11rem;
		height: 0.35rem;
		border-radius: 999px;
		background: var(--color-accent);
	}

	.featured-system__panel {
		display: grid;
		gap: 1.1rem;
		padding: clamp(1.25rem, 3vw, 2rem);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.featured-system__rule {
		width: 10ch;
		margin: 0;
	}

	.featured-system__eyebrow {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.featured-system__rails {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		margin: 0.4rem 0 0;
		padding: 0;
	}

	.featured-system__rail {
		display: grid;
		grid-template-columns: 4.5rem 1fr;
		gap: 1.25rem;
		align-items: center;
		padding: 0.8rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.featured-system__rail:last-child {
		border-bottom: none;
	}

	.featured-system__rail-shape {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3.25rem;
	}

	.featured-system__rail-copy {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.featured-system__rail-copy span {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.featured-system__rail-copy p {
		margin: 0;
		font-size: 0.96rem;
		line-height: 1.5;
		color: var(--color-text);
		max-width: 44ch;
	}

	.home-hero__poster {
		position: relative;
		min-height: clamp(18rem, 34vw, 28rem);
	}

	.home-hero__poster-circle {
		position: absolute;
		top: 0;
		right: 0;
	}

	.home-hero__poster-rect {
		position: absolute;
		top: clamp(7rem, 16vw, 14rem);
		right: clamp(7rem, 17vw, 16rem);
	}

	.home-hero__poster-half {
		position: absolute;
		bottom: clamp(0rem, 4vw, 3rem);
		left: 0;
	}

	.home-hero__poster-dots {
		position: absolute;
		bottom: 0;
		right: clamp(1rem, 2vw, 2rem);
	}

	.capability-loop__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0;
		border-top: 1px solid var(--color-border);
	}

	.loop-step {
		padding: 1.4rem clamp(1rem, 1.5vw, 1.4rem) 1.5rem;
		border-right: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.loop-step:nth-child(4n) {
		border-right: none;
	}

	.loop-step__glyph {
		display: flex;
		align-items: flex-end;
		gap: 0.4rem;
		margin-bottom: 1rem;
		min-height: 2.2rem;
	}

	.loop-step__glyph--multiply {
		gap: 0.35rem;
	}

	.loop-step__num,
	.research-proof__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.loop-step__num {
		color: var(--color-accent);
		margin-bottom: 0.5rem;
	}

	.loop-step h3,
	.method-row h3,
	.research-proof__featured h3,
	.research-proof__secondary-item h3 {
		margin-bottom: 0.6rem;
	}

	.stats-section {
		padding: clamp(2.5rem, 5vw, 4rem) 0;
	}

	.stats {
		list-style: none;
		padding: clamp(1.5rem, 3vw, 2.25rem) 0;
		margin: 0;
