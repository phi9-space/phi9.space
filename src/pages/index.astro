---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import DotGrid from "@components/visuals/DotGrid.astro";
import HalfCircle from "@components/visuals/HalfCircle.astro";
import InkRect from "@components/visuals/InkRect.astro";
import SignalCircle from "@components/visuals/SignalCircle.astro";
import VerticalBar from "@components/visuals/VerticalBar.astro";
import { contactMailto, formatLongDate, getReadingTime } from "@lib/site";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const featuredPost = latestPosts[0] ?? null;
const secondaryPosts = featuredPost ? latestPosts.slice(1, 3) : latestPosts.slice(0, 2);

const structuredData = {
	"@context": "https://schema.org",
	"@type": "Organization",
	name: "phi9.space",
	url: "https://phi9.space",
	description: "Physical AI research, data systems, and deployable intelligence.",
};

const capabilityLoop = [
	{
		id: "capture",
		num: "001",
		title: "Capture",
		desc: "Capture real-world demonstrations with synchronized motion, video, and structured task data.",
	},
	{
		id: "multiply",
		num: "002",
		title: "Multiply",
		desc: "Multiply scarce data through retargeting, simulation, augmentation, and better structure.",
	},
	{
		id: "train",
		num: "003",
		title: "Train",
		desc: "Train policies and research systems on data that preserves intent, motion, and context.",
	},
	{
		id: "evaluate",
		num: "004",
		title: "Evaluate",
		desc: "Evaluate what generalizes through benchmarks, failure analysis, and transfer tests.",
	},
];

const openProblems = [
	{
		title: "Data that carries intent, not just observation.",
		desc: "Most pipelines still capture what happened on screen, not what the body did, what the task required, or what the demonstration was trying to achieve.",
	},
	{
		title: "Generalization from scarce real-world behavior.",
		desc: "Physical data is expensive, messy, and uneven. Scaling it requires better multiplication, not just more collection.",
	},
	{
		title: "Evaluation that predicts transfer.",
		desc: "Benchmarks are useful only if they tell us what survives outside the benchmark.",
	},
	{
		title: "Research systems that close the loop.",
		desc: "Capture, structure, training, and evaluation are still too often treated as separate problems.",
	},
];

const methods = [
	{
		title: "Capture in the world.",
		desc: "Start from real signal: motion, video, task context, and synchronized traces.",
	},
	{
		title: "Structure for reuse.",
		desc: "Package demonstrations so they remain legible for training, research, and downstream operations.",
	},
	{
		title: "Multiply without drift.",
		desc: "Use simulation, retargeting, and augmentation to extend scarce real behavior while preserving intent.",
	},
	{
		title: "Evaluate for transfer.",
		desc: "Treat benchmarks, failure analysis, and deployment feedback as part of one loop.",
	},
];

const principles = [
	{
		title: "Presence over pitch.",
		desc: "The public surface should feel authored, precise, and calm.",
	},
	{
		title: "Soul on the surface, rigor underneath.",
		desc: "Language carries worldview; proof follows quickly.",
	},
	{
		title: "Artifacts before abstractions.",
		desc: "Show what the work is before talking about what it could become.",
	},
	{
		title: "Research infrastructure is part of the product.",
		desc: "Systems and workflows belong on the surface because they are part of the value.",
	},
	{
		title: "Progress should remain legible.",
		desc: "Open work, partial systems, and active questions keep progress visible.",
	},
];
---

<BaseLayout
	fullWidth={true}
	structuredData={structuredData}
	title="phi9.space"
	description="Physical AI research, data systems, and deployable intelligence."
>
	<section class="home-hero">
		<div class="container">
			<div class="home-hero__grid">
				<div class="home-hero__content reveal">
					<p class="home-hero__eyebrow">Phi9 — physical AI lab</p>
					<h1 class="display-xl">
						Physical AI research, data systems, and deployable intelligence.
					</h1>
					<span class="rule" aria-hidden="true"></span>
					<p class="home-hero__copy">
						Phi9 builds the systems that turn physical behavior into usable intelligence. We
						capture data in the world, structure it for training, and use it to build research
						infrastructure, products, and evaluation loops for physical AI.
					</p>
					<div class="home-hero__actions">
						<a href="/lab" class="btn btn-primary">Explore the Lab</a>
						<a href="/data" class="btn btn-secondary">See the Data</a>
					</div>
				</div>

				<div class="home-hero__poster reveal" aria-hidden="true">
					<div class="home-hero__poster-circle">
						<SignalCircle size="clamp(12rem, 26vw, 22rem)" />
					</div>
					<div class="home-hero__poster-rect">
						<InkRect
							width="clamp(5rem, 10vw, 8.5rem)"
							height="clamp(10rem, 22vw, 19rem)"
						/>
					</div>
					<div class="home-hero__poster-half">
						<HalfCircle
							size="clamp(8rem, 18vw, 15rem)"
							orientation="left"
						/>
					</div>
					<div class="home-hero__poster-dots">
						<DotGrid rows={6} cols={8} spacing="0.55rem" dotSize="0.3rem" />
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section capability-loop">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">The loop</span>
				<h2>From capture to evaluation, the physical AI loop.</h2>
				<p>
					Physical AI does not move forward through models alone. It moves through systems
					that can capture behavior, multiply usable data, train against reality, and evaluate
					what actually transfers.
				</p>
			</div>

			<div class="capability-loop__grid">
				{
					capabilityLoop.map((item) => (
						<article class="loop-step reveal">
							<span class="loop-step__num">{item.num}</span>
							<h3>{item.title}</h3>
							<p>{item.desc}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section featured-system">
		<div class="container">
			<div class="featured-system__grid">
				<div class="featured-system__frame reveal" aria-hidden="true">
					<span class="featured-system__rule"></span>
					<p class="featured-system__eyebrow">MoCap Rig v1 / featured system</p>
					<div class="featured-system__surface">
						<div class="featured-system__surface-card">
							<span>capture</span>
							<p>Motion + video + structured task traces</p>
						</div>
						<div class="featured-system__surface-card featured-system__surface-card--small">
							<span>quality</span>
							<p>Aligned multimodal data</p>
						</div>
						<div class="featured-system__surface-card featured-system__surface-card--small">
							<span>output</span>
							<p>Research-ready demonstrations</p>
						</div>
					</div>
					<p class="featured-system__caption">
						Large product image or technical composite anchored in the working system.
					</p>
				</div>

				<div class="featured-system__content reveal">
					<span class="section-kicker">Featured system</span>
					<h2>Data capture built for physical AI.</h2>
					<p>
						Phi9 MoCap Rig is one part of a larger data surface. It captures full-body motion,
						synchronized egocentric video, and structured task traces that can be used for
						research, post-training, and deployment workflows.
					</p>
					<a href="/data" class="featured-system__link">See the Data</a>
				</div>
			</div>
		</div>
	</section>

	<section class="section research-proof">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Research</span>
				<h2>Open work, real artifacts, and technical evidence.</h2>
				<p>
					Our research log tracks the systems, experiments, and questions that shape the lab.
					The goal is not volume. The goal is legible progress.
				</p>
			</div>

			<div class="research-proof__grid">
				{
					featuredPost ? (
						<a href={`/research/${featuredPost.slug}`} class="research-proof__featured reveal">
							<div class="research-proof__media">
								{
									featuredPost.data.heroImage ? (
										<img
											src={featuredPost.data.heroImage}
											alt={featuredPost.data.title}
											loading="lazy"
										/>
									) : (
										<div class="research-proof__placeholder">
											<span class="research-proof__placeholder-rule"></span>
											<p>Featured research item</p>
										</div>
									)
								}
							</div>
							<div class="research-proof__meta">
								{featuredPost.data.tags[0] && <span>{featuredPost.data.tags[0]}</span>}
								<time datetime={featuredPost.data.pubDate.toISOString()}>
									{formatLongDate(featuredPost.data.pubDate)}
								</time>
								<span>{getReadingTime(featuredPost.body)} min</span>
							</div>
							<h3>{featuredPost.data.title}</h3>
							<p>{featuredPost.data.description}</p>
						</a>
					) : (
						<div class="research-proof__featured reveal">
							<div class="research-proof__placeholder research-proof__placeholder--featured">
								<span class="research-proof__placeholder-rule"></span>
								<p>Featured research item</p>
							</div>
							<div class="research-proof__meta">
								<span>Research</span>
								<span>Archive feeling</span>
							</div>
							<h3>Open work, real artifacts, and technical evidence.</h3>
							<p>Use dates, tags, and figures to make the archive feel active.</p>
						</div>
					)
				}

				<div class="research-proof__secondary">
					{
						secondaryPosts.length > 0 ? (
							secondaryPosts.map((post) => (
								<a href={`/research/${post.slug}`} class="research-proof__secondary-item reveal">
									<div class="research-proof__secondary-copy">
										<div class="research-proof__meta">
											{post.data.tags[0] && <span>{post.data.tags[0]}</span>}
											<time datetime={post.data.pubDate.toISOString()}>
												{formatLongDate(post.data.pubDate)}
											</time>
										</div>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
									</div>
									<div class="research-proof__secondary-thumb">
										{
											post.data.heroImage ? (
												<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
											) : (
												<div class="research-proof__placeholder research-proof__placeholder--thumb">
													<span class="research-proof__placeholder-rule"></span>
												</div>
											)
										}
									</div>
								</a>
							))
						) : (
							<>
								<div class="research-proof__secondary-item reveal">
									<div class="research-proof__secondary-copy">
										<div class="research-proof__meta">
											<span>Research</span>
											<span>Technical crop</span>
										</div>
										<h3>Secondary item 01 / figure crop</h3>
										<p>Use dates, tags, and reading time in mono. Research should feel active.</p>
									</div>
									<div class="research-proof__placeholder research-proof__placeholder--thumb">
										<span class="research-proof__placeholder-rule"></span>
									</div>
								</div>
								<div class="research-proof__secondary-item reveal">
									<div class="research-proof__secondary-copy">
										<div class="research-proof__meta">
											<span>Research</span>
											<span>Notebook fragment</span>
										</div>
										<h3>Secondary item 02 / notebook fragment</h3>
										<p>Use a figure, fragment, or technical note to extend the story.</p>
									</div>
									<div class="research-proof__placeholder research-proof__placeholder--thumb">
										<span class="research-proof__placeholder-rule"></span>
									</div>
								</div>
							</>
						)
					}
				</div>
			</div>
		</div>
	</section>

	<section class="section open-problems">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Open problems</span>
				<h2>
					Some bottlenecks are still obvious.
				</h2>
				<p>
					The work is deciding which ones are structural and which ones are only temporary.
				</p>
			</div>

			<div class="open-problems__grid">
				{
					openProblems.map((problem) => (
						<article class="problem-card reveal">
							<h3>{problem.title}</h3>
							<p>{problem.desc}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section methods">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Methods</span>
				<h2>We build loops, not isolated models.</h2>
				<p>
					Phi9 works across capture systems, data infrastructure, training workflows, and
					evaluation. The point is to reduce distance between demonstration, learning, and real
					deployment.
				</p>
			</div>

			<div class="methods__rows">
				{
					methods.map((item) => (
						<div class="method-row reveal">
							<h3>{item.title}</h3>
							<p>{item.desc}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="section principles">
		<div class="container">
			<div class="section-heading reveal">
				<span class="section-kicker">Principles</span>
				<h2>The beliefs that hold the work together.</h2>
			</div>

			<div class="principles__rows">
				{
					principles.map((item) => (
						<div class="principle-row reveal">
							<h3>{item.title}</h3>
							<p>{item.desc}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="section newsletter-section">
		<div class="container">
			<div class="newsletter reveal">
				<h2>Research Dispatch</h2>
				<p class="newsletter__description">
					Technical writing on physical AI, datasets, and deployment.
					Published when there is something worth sharing.
				</p>
				<a
					href="https://substack.com/@phi9"
					target="_blank"
					rel="noopener noreferrer"
					class="btn btn-primary newsletter__button"
				>
					Subscribe on Substack
				</a>
				<p class="newsletter__privacy">No spam. One-click unsubscribe anytime.</p>
			</div>
		</div>
	</section>

	<section class="section contact-section">
		<div class="container">
			<div class="contact-cta reveal">
				<span class="section-kicker">Get in touch</span>
				<div class="contact-cta__content">
					<h2>Building in physical AI?</h2>
					<p>
						If you are working on data, research systems, or deployment infrastructure for
						physical intelligence, get in touch.
					</p>
				</div>
				<div class="contact-cta__actions">
					<a href={contactMailto} class="btn btn-primary contact-cta__button">
						Get in touch
					</a>
					<a href="/manifesto" class="btn btn-secondary contact-cta__button">
						Read manifesto
					</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.home-hero {
		background: var(--gradient-hero);
		padding: clamp(7rem, 12vw, 10rem) 0 clamp(3.5rem, 6vw, 5rem);
	}

	.home-hero__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(280px, 1fr);
		gap: clamp(2rem, 4vw, 4rem);
		align-items: start;
	}

	.featured-system__grid,
	.research-proof__grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
		gap: clamp(2rem, 4vw, 3.5rem);
		align-items: start;
	}

	.home-hero__content {
		padding-top: clamp(0.5rem, 3vw, 1.25rem);
	}

	.home-hero__eyebrow {
		margin: 0 0 1.25rem;
		font-family: var(--font-mono);
		font-size: clamp(0.78rem, 1.1vw, 0.9rem);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.home-hero__content .display-xl {
		margin: 0 0 1.25rem;
		max-width: 18ch;
	}

	.home-hero__content .rule {
		margin: 0 0 1.5rem;
		width: 12ch;
	}

	.home-hero__copy,
	.section-heading p,
	.featured-system__content p,
	.problem-card p,
	.method-row p,
	.principle-row p,
	.research-proof__featured p,
	.research-proof__secondary-item p {
		color: var(--color-muted);
		max-width: 62ch;
	}

	.home-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.75rem;
	}

	.section-kicker {
		display: inline-block;
		margin-bottom: 0.8rem;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.section-kicker--inverse {
		color: color-mix(in srgb, var(--color-text-inverse) 82%, var(--color-accent) 18%);
	}

	.section-heading {
		display: grid;
		gap: 0.6rem;
		margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
		max-width: 50rem;
	}

	.featured-system__frame,
	.research-proof__featured,
	.research-proof__secondary-item,
	.problem-card {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xl);
		background: color-mix(in srgb, var(--color-bg) 80%, var(--color-surface) 20%);
	}

	.featured-system__rule,
	.research-proof__placeholder-rule {
		display: block;
		width: 11rem;
		height: 0.35rem;
		border-radius: 999px;
		background: var(--color-accent);
	}

	.featured-system__eyebrow {
		margin: 0;
		font-family: var(--font-heading);
		font-size: 1.05rem;
	}

	.featured-system__caption {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		letter-spacing: 0.04em;
		color: var(--color-muted);
		text-transform: uppercase;
	}

	.home-hero__poster {
		position: relative;
		min-height: clamp(18rem, 34vw, 28rem);
	}

	.home-hero__poster-circle {
		position: absolute;
		top: 0;
		right: 0;
	}

	.home-hero__poster-rect {
		position: absolute;
		top: clamp(7rem, 16vw, 14rem);
		right: clamp(7rem, 17vw, 16rem);
	}

	.home-hero__poster-half {
		position: absolute;
		bottom: clamp(0rem, 4vw, 3rem);
		left: 0;
	}

	.home-hero__poster-dots {
		position: absolute;
		bottom: 0;
		right: clamp(1rem, 2vw, 2rem);
	}

	.capability-loop__grid,
	.open-problems__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.loop-step,
	.problem-card {
		padding: 1.2rem 1.2rem 1.35rem;
	}

	.loop-step {
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.loop-step__num,
	.research-proof__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.loop-step__num {
		color: var(--color-accent);
		margin-bottom: 0.7rem;
	}

	.loop-step h3,
	.problem-card h3,
	.method-row h3,
	.principle-row h3,
	.research-proof__featured h3,
	.research-proof__secondary-item h3 {
		margin-bottom: 0.6rem;
	}

	.featured-system__frame {
		padding: 1.6rem;
		display: grid;
		gap: 0.9rem;
	}

	.featured-system__surface {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		grid-template-areas:
			"main detail-a"
			"main detail-b";
		gap: 0.85rem;
		min-height: 18rem;
	}

	.featured-system__surface-card {
		grid-area: main;
		padding: 1.15rem;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background: var(--color-bg);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 15rem;
	}

	.featured-system__surface-card--small {
		min-height: 7.15rem;
	}

	.featured-system__surface-card--small:first-of-type {
		grid-area: detail-a;
	}

	.featured-system__surface-card--small:last-of-type {
		grid-area: detail-b;
	}

	.featured-system__surface-card span {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.featured-system__surface-card p {
		margin: 0;
		font-family: var(--font-heading);
		font-size: 1.2rem;
		line-height: 1.2;
	}

	.featured-system__content {
		padding-top: 0.35rem;
	}

	.featured-system__link {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.research-proof__grid {
		align-items: stretch;
	}

	.research-proof__featured,
	.research-proof__secondary-item {
		padding: 1rem;
		text-decoration: none;
		color: inherit;
	}

	.research-proof__featured:hover,
	.research-proof__secondary-item:hover {
		text-decoration: none;
	}

	.research-proof__media,
	.research-proof__secondary-thumb,
	.research-proof__placeholder {
		overflow: hidden;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
	}

	.research-proof__media {
		aspect-ratio: 16 / 10;
		margin-bottom: 1rem;
	}

	.research-proof__secondary {
		display: grid;
		gap: 1rem;
	}

	.research-proof__secondary-item {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 11rem;
		gap: 1rem;
		align-items: stretch;
	}

	.research-proof__secondary-thumb {
		height: 100%;
		min-height: 8.5rem;
	}

	.research-proof__placeholder,
	.research-proof__placeholder--thumb,
	.research-proof__placeholder--featured {
