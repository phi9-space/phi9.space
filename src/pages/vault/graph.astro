---
import manifest from "@generated/vault-manifest.json";
import VaultLayout from "@layouts/VaultLayout.astro";

const nodes = (manifest.nodes || []).filter((node) => node.type === "note" || node.type === "dataset");
const edges = manifest.edges || [];
const categories = Array.from(new Set(nodes.map((node) => node.category))).sort((a, b) =>
	a.localeCompare(b),
);
const tags = Array.from(new Set(nodes.flatMap((node) => node.tags || []))).sort((a, b) =>
	a.localeCompare(b),
);
const serializedGraphData = JSON.stringify({ nodes, edges });
---

<VaultLayout title="Vault Graph — phi9.space" description="Interactive graph of public vault notes.">
  <section>
    <p class="section-kicker">Graph</p>
    <h1>Public note graph</h1>
    <p class="section-intro">
      Filter by type, category, and tag. Click any node to open the note.
    </p>
  </section>

  <section class="graph-controls">
    <label>
      Type
      <select data-filter-type>
        <option value="all">All</option>
        <option value="note">note</option>
        <option value="dataset">dataset</option>
      </select>
    </label>

    <label>
      Category
      <select data-filter-category>
        <option value="all">All</option>
        {categories.map((category) => <option value={category}>{category}</option>)}
      </select>
    </label>

    <label>
      Tag
      <select data-filter-tag>
        <option value="all">All</option>
        {tags.map((tag) => <option value={tag}>{tag}</option>)}
      </select>
    </label>
  </section>

  <section class="graph-stage" data-graph-stage>
    <svg viewBox="0 0 980 620" data-graph-svg aria-label="Vault graph visualization"></svg>
  </section>

  <script type="application/json" id="graph-data" set:html={serializedGraphData}></script>

  <script is:inline>
    const graphDataElement = document.getElementById("graph-data");
    const graphData = graphDataElement ? JSON.parse(graphDataElement.textContent || "{}") : { nodes: [], edges: [] };
    const svg = document.querySelector("[data-graph-svg]");
    const typeFilter = document.querySelector("[data-filter-type]");
    const categoryFilter = document.querySelector("[data-filter-category]");
    const tagFilter = document.querySelector("[data-filter-tag]");

    function colorForType(type) {
      if (type === "dataset") return "var(--color-success)";
      return "var(--color-accent)";
    }

    function renderGraph() {
      if (!svg) return;
      const selectedType = typeFilter?.value || "all";
      const selectedCategory = categoryFilter?.value || "all";
      const selectedTag = tagFilter?.value || "all";

      const visibleNodes = graphData.nodes.filter((node) => {
        if (selectedType !== "all" && node.type !== selectedType) return false;
        if (selectedCategory !== "all" && node.category !== selectedCategory) return false;
        if (selectedTag !== "all" && !(node.tags || []).includes(selectedTag)) return false;
        return true;
      });

      const visibleSet = new Set(visibleNodes.map((node) => node.slug));
      const visibleEdges = graphData.edges.filter(
        (edge) => visibleSet.has(edge.source) && visibleSet.has(edge.target),
      );

      svg.innerHTML = "";
      if (visibleNodes.length === 0) {
        const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
        text.setAttribute("x", "490");
        text.setAttribute("y", "320");
        text.setAttribute("text-anchor", "middle");
        text.setAttribute("fill", "var(--color-muted)");
        text.textContent = "No nodes for this filter.";
        svg.append(text);
        return;
      }

      const centerX = 490;
      const centerY = 310;
      const radius = Math.min(250, 70 + visibleNodes.length * 6);
      const nodePositions = new Map();

      visibleNodes.forEach((node, index) => {
        const angle = (Math.PI * 2 * index) / visibleNodes.length;
        const x = centerX + radius * Math.cos(angle);
        const y = centerY + radius * Math.sin(angle);
        nodePositions.set(node.slug, { x, y, node });
      });

      const edgeLayer = document.createElementNS("http://www.w3.org/2000/svg", "g");
      edgeLayer.setAttribute("opacity", "0.5");
      svg.append(edgeLayer);

      for (const edge of visibleEdges) {
        const source = nodePositions.get(edge.source);
        const target = nodePositions.get(edge.target);
        if (!source || !target) continue;
        const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
        line.setAttribute("x1", String(source.x));
        line.setAttribute("y1", String(source.y));
        line.setAttribute("x2", String(target.x));
        line.setAttribute("y2", String(target.y));
        line.setAttribute("stroke", "var(--color-border)");
        line.setAttribute("stroke-width", "1");
        edgeLayer.append(line);
      }

      const nodeLayer = document.createElementNS("http://www.w3.org/2000/svg", "g");
      svg.append(nodeLayer);

      for (const { x, y, node } of nodePositions.values()) {
        const link = document.createElementNS("http://www.w3.org/2000/svg", "a");
        link.setAttribute("href", node.url);

        const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        circle.setAttribute("cx", String(x));
        circle.setAttribute("cy", String(y));
        circle.setAttribute("r", "8");
        circle.setAttribute("fill", colorForType(node.type));
        circle.setAttribute("stroke", "var(--color-bg)");
        circle.setAttribute("stroke-width", "2");

        const title = document.createElementNS("http://www.w3.org/2000/svg", "title");
        title.textContent = `${node.title} (${node.type} · ${node.category})`;
        circle.append(title);

        const label = document.createElementNS("http://www.w3.org/2000/svg", "text");
        label.setAttribute("x", String(x + 12));
        label.setAttribute("y", String(y + 4));
        label.setAttribute("fill", "var(--color-text)");
        label.setAttribute("font-size", "12");
        label.textContent = node.title;

        link.append(circle);
        link.append(label);
        nodeLayer.append(link);
      }
    }

    [typeFilter, categoryFilter, tagFilter].forEach((el) => {
      el?.addEventListener("change", renderGraph);
    });

    renderGraph();
  </script>
</VaultLayout>

<style>
  .section-kicker {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .section-intro {
    margin-top: 0.3rem;
    color: var(--color-muted);
  }

  .graph-controls {
    margin: 1rem 0;
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }

  .graph-controls label {
    display: grid;
    gap: 0.24rem;
    font-size: 0.86rem;
    color: var(--color-muted);
  }

  .graph-controls select {
    border: 1px solid var(--color-border);
    border-radius: 0.35rem;
    background: var(--color-bg-elevated);
    color: var(--color-text);
    padding: 0.35rem 0.42rem;
  }

  .graph-stage {
    border: 1px solid var(--color-border);
    border-radius: 0.7rem;
    background: var(--color-bg-elevated);
    overflow: hidden;
    min-height: 420px;
  }

  .graph-stage svg {
    width: 100%;
    height: 100%;
    min-height: 420px;
  }
</style>
