---
import { getEntry } from "astro:content";
import MarkdownRenderer from "@components/MarkdownRenderer.astro";
import manifest from "@generated/vault-manifest.json";
import VaultLayout from "@layouts/VaultLayout.astro";

export async function getStaticPaths() {
	return (manifest.nodes || []).map((node) => ({
		params: { slug: node.slug },
	}));
}

const slug = Astro.params.slug || "";
const entry = await getEntry("vault", slug);

if (!entry) {
	throw new Error(`Vault note missing for slug: ${slug}`);
}

const isDataset = entry.data.type === "dataset";
const isProduct = entry.data.type === "product";
const redirectTarget = isDataset ? `/datasets/${entry.slug}/` : isProduct ? "/lab/" : "";

if (redirectTarget) {
	Astro.response.headers.set("Location", redirectTarget);
	Astro.response.status = 308;
}

const nodesBySlug = new Map((manifest.nodes || []).map((node) => [node.slug, node]));

let Content: Awaited<ReturnType<typeof entry.render>>["Content"] | null = null;
let headings: Awaited<ReturnType<typeof entry.render>>["headings"] = [];
let backlinks: Array<{ source: string; title: string; url: string }> = [];

if (!isDataset && !isProduct) {
	const rendered = await entry.render();
	Content = rendered.Content;
	headings = rendered.headings;
	backlinks = (manifest.edges || [])
		.filter((edge) => edge.target === entry.slug)
		.map((edge) => {
			const sourceNode = nodesBySlug.get(edge.source);
			return sourceNode
				? {
					source: edge.source,
					title: sourceNode.title,
					url: sourceNode.url,
				}
				: null;
		})
		.filter(Boolean) as Array<{ source: string; title: string; url: string }>;
}

const properties = {
	type: entry.data.type,
	category: entry.data.category,
	datasetKind: entry.data.datasetKind,
	status: entry.data.status,
	featured: entry.data.featured,
	series: entry.data.series ?? null,
	tags: entry.data.tags,
	slug: entry.slug,
	updated: entry.data.updated ? entry.data.updated.toISOString() : null,
	date: entry.data.date ? entry.data.date.toISOString() : null,
	sourcePath: entry.data.sourcePath,
};

function getEmbedFromVideo(video: string | undefined) {
	if (!video) return null;
	if (video.startsWith("/")) {
		return { type: "local", src: video } as const;
	}
	try {
		const url = new URL(video);
		if (["youtube.com", "www.youtube.com", "youtu.be"].includes(url.hostname)) {
			let id = url.searchParams.get("v");
			if (!id) {
				id = url.pathname.split("/").filter(Boolean).at(-1) || null;
			}
			if (!id) return null;
			return {
				type: "iframe",
				src: `https://www.youtube.com/embed/${id}`,
			} as const;
		}
		if (["vimeo.com", "www.vimeo.com", "player.vimeo.com"].includes(url.hostname)) {
			const id = url.pathname.split("/").filter(Boolean).reverse().find((part) => /^\d+$/.test(part));
			if (!id) return null;
			return {
				type: "iframe",
				src: `https://player.vimeo.com/video/${id}`,
			} as const;
		}
		return null;
	} catch {
		return null;
	}
}

const videoEmbed = getEmbedFromVideo(entry.data.video);
---

{
	redirectTarget ? (
		<html lang="en">
		  <head>
		    <meta charset="utf-8" />
		    <meta http-equiv="refresh" content={`0; url=${redirectTarget}`} />
		    <title>Redirecting…</title>
		    <link rel="canonical" href={redirectTarget} />
		  </head>
		  <body>
		    <p>
		      Redirecting to <a href={redirectTarget}>{redirectTarget}</a>.
		    </p>
		  </body>
		</html>
	) : (
		<VaultLayout
			title={`${entry.data.title} — Vault — phi9.space`}
			description={entry.data.description}
			currentSlug={entry.slug}
			headings={headings}
			backlinks={backlinks}
			properties={properties}
		>
		  <article>
		    <p class="note-kicker">
		      {entry.data.type} · {entry.data.category} · {entry.data.status}
		      {entry.data.featured ? " · featured" : ""}
		      {entry.data.series ? ` · series: ${entry.data.series}` : ""}
		    </p>
		    <h1>{entry.data.title}</h1>
		    {entry.data.description && <p class="note-description">{entry.data.description}</p>}
    {entry.data.tags.length > 0 && (
      <p class="note-tags">
        {entry.data.tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </p>
    )}

		    {entry.data.cover && (
		      <figure class="vault-media vault-media--image note-cover">
		        <img src={entry.data.cover} alt={entry.data.title} loading="lazy" />
		      </figure>
		    )}

		    {videoEmbed?.type === "local" && (
		      <figure class="vault-media vault-media--video note-video">
		        <video controls preload="metadata" src={videoEmbed.src}></video>
		      </figure>
		    )}

		    {videoEmbed?.type === "iframe" && (
		      <div class="external-embed note-video">
		        <iframe
		          src={videoEmbed.src}
		          title={entry.data.title}
		          loading="lazy"
		          allow="autoplay; fullscreen; picture-in-picture"
		          allowfullscreen
		        ></iframe>
		      </div>
		    )}

		    {Content && <MarkdownRenderer Content={Content} raw={entry.body} />}
		  </article>
		</VaultLayout>
	)
}

<style>
  .note-kicker {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .note-description {
    margin-top: 0.3rem;
    color: var(--color-muted);
    max-width: 72ch;
  }

  .note-tags {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin: 0.4rem 0 1rem;
  }

  .note-tags a {
    padding: 0;
    background: transparent;
    color: var(--color-link);
    font-size: 0.82rem;
  }

  .note-cover,
  .note-video {
    margin-bottom: 1rem;
    max-width: 900px;
  }
</style>
