---
import { getEntry } from "astro:content";
import DocumentLayout from "@layouts/DocumentLayout.astro";

const page = await getEntry("pages", "manifesto");
if (!page) {
	throw new Error("Pages collection: entry 'manifesto' not found. Run `astro sync` and restart dev server.");
}
const { Content } = await page.render();
---

<DocumentLayout
	entry={page}
	Content={Content}
	eyebrow="Manifesto"
	showContactCTA
	contactHeadline="Working toward physical intelligence?"
	contactBody="If this aligns with what you are building — in data, research, or deployment — write to us."
	contactSecondaryHref="/research"
	contactSecondaryLabel="Read the research"
/>
