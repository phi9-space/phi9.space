---
interface Props {
	url: string;
	title: string;
	class?: string;
}

const { url, title, class: className = "" } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class:list={["share-bar", className]}>
	<span class="share-bar__label">Share</span>
	<ul class="share-bar__actions">
		<li>
			<button
				type="button"
				class="share-bar__btn"
				data-share-copy
				data-url={url}
				aria-label="Copy link"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M10 14a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07L11 6M14 10a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07L13 18"
						fill="none"
						stroke="currentColor"
						stroke-width="1.6"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
				<span class="share-bar__text">Copy link</span>
			</button>
		</li>
		<li>
			<a
				class="share-bar__btn"
				href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Share on X"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M4 4l7.5 10L4 20h3l6.2-6.2L18 20h3l-7.8-10.5L20.5 4h-3l-5.5 5.8L8 4H4z"
						fill="currentColor"
					/>
				</svg>
				<span class="share-bar__text">X</span>
			</a>
		</li>
		<li>
			<a
				class="share-bar__btn"
				href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Share on LinkedIn"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M4.5 3.5a2 2 0 1 1 0 4 2 2 0 0 1 0-4zM3 9h3v11H3V9zm5 0h2.9v1.5h.04c.4-.76 1.4-1.56 2.88-1.56 3.08 0 3.65 2.02 3.65 4.65V20H14.5v-4.9c0-1.17-.02-2.68-1.63-2.68-1.64 0-1.89 1.28-1.89 2.6V20H8V9z"
						fill="currentColor"
					/>
				</svg>
				<span class="share-bar__text">LinkedIn</span>
			</a>
		</li>
		<li>
			<a
				class="share-bar__btn"
				href={`mailto:?subject=${encodedTitle}&body=${encodedUrl}`}
				aria-label="Share via email"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M3.5 5.5h17a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1h-17a1 1 0 0 1-1-1v-11a1 1 0 0 1 1-1z"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
					/>
					<path
						d="M3.8 6.2L12 13l8.2-6.8"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
					/>
				</svg>
				<span class="share-bar__text">Email</span>
			</a>
		</li>
	</ul>
</div>

<script is:inline>
	for (const btn of document.querySelectorAll("[data-share-copy]")) {
		btn.addEventListener("click", async () => {
			const link = btn.getAttribute("data-url");
			if (!link) return;
			try {
				await navigator.clipboard.writeText(link);
			} catch (err) {
				const textarea = document.createElement("textarea");
				textarea.value = link;
				textarea.style.position = "fixed";
				textarea.style.opacity = "0";
				document.body.appendChild(textarea);
				textarea.select();
				try {
					document.execCommand("copy");
				} catch {
					// ignore
				}
				document.body.removeChild(textarea);
			}
			const label = btn.querySelector(".share-bar__text");
			if (label) {
				const original = label.textContent;
				label.textContent = "Copied";
				btn.setAttribute("data-copied", "true");
				setTimeout(() => {
					label.textContent = original;
					btn.removeAttribute("data-copied");
				}, 1800);
			}
		});
	}
</script>

<style>
	.share-bar {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.share-bar__label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.share-bar__actions {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		margin: 0;
		padding: 0;
	}

	.share-bar__btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.45rem 0.7rem 0.45rem 0.55rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: transparent;
		color: var(--color-text);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.02em;
		text-decoration: none;
		cursor: pointer;
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background 0.15s ease;
		width: 100%;
	}

	.share-bar__btn svg {
		width: 1rem;
		height: 1rem;
		flex-shrink: 0;
	}

	.share-bar__btn:hover {
		color: var(--color-accent);
		border-color: color-mix(in srgb, var(--color-accent) 55%, var(--color-border) 45%);
		text-decoration: none;
	}

	.share-bar__btn[data-copied="true"] {
		color: var(--color-accent);
		border-color: var(--color-accent);
	}

	.share-bar__text {
		font-weight: 500;
	}

	@media (max-width: 800px) {
		.share-bar__actions {
			flex-direction: row;
			flex-wrap: wrap;
		}

		.share-bar__btn {
			width: auto;
		}
	}
</style>
