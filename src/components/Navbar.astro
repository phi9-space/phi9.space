---
const links = [
	{ href: "/lab/about", label: "About" },
	{ href: "/lab", label: "Lab" },
	{ href: "/research", label: "Research" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<div class="site-nav">
  <a class="site-nav__brand" href="/" aria-label="phi9.space home">
    <img src="/PHI9.SPACE.svg" alt="phi9.space" loading="lazy" />
  </a>
  <button
    type="button"
    class="site-nav__toggle"
    data-nav-toggle
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="site-nav-menu"
  >
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
    </svg>
  </button>
  <nav aria-label="Primary" id="site-nav-menu" class="site-nav__menu" data-nav-menu>
    <ul>
      {links.map((item) => {
        const normalizedHref = item.href.replace(/\/$/, "") || "/";
        const prefixMatch =
          currentPath === normalizedHref ||
          (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
        const shadowed = prefixMatch && links.some((other) => {
          const otherHref = other.href.replace(/\/$/, "") || "/";
          return otherHref !== normalizedHref
            && otherHref.startsWith(`${normalizedHref}/`)
            && (currentPath === otherHref || currentPath.startsWith(`${otherHref}/`));
        });
        const active = prefixMatch && !shadowed;

        return (
          <li>
            <a href={item.href} data-active={active ? "true" : "false"}>
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</div>

<script is:inline>
  const navRoot = document.querySelector(".site-nav");
  const navToggle = navRoot?.querySelector("[data-nav-toggle]");
  const navMenu = navRoot?.querySelector("[data-nav-menu]");
  const navLinks = navMenu ? Array.from(navMenu.querySelectorAll("a")) : [];

  const closeMenu = () => {
    if (!navRoot || !navToggle) return;
    navRoot.setAttribute("data-menu-open", "false");
    navToggle.setAttribute("aria-expanded", "false");
  };

  const openMenu = () => {
    if (!navRoot || !navToggle) return;
    navRoot.setAttribute("data-menu-open", "true");
    navToggle.setAttribute("aria-expanded", "true");
  };

  navToggle?.addEventListener("click", () => {
    const isOpen = navRoot?.getAttribute("data-menu-open") === "true";
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  for (const link of navLinks) {
    link.addEventListener("click", closeMenu);
  }

  window.addEventListener("resize", () => {
    if (window.innerWidth > 900) {
      closeMenu();
    }
  });
</script>

<style>
  .site-nav {
    max-width: 1180px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 0.95rem clamp(1rem, 2vw, 2rem);
  }

  .site-nav__toggle {
    display: none;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    color: var(--color-text);
    border-radius: 0.4rem;
    width: 2.1rem;
    height: 2.1rem;
    padding: 0;
    font: inherit;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .site-nav__toggle svg {
    width: 1.02rem;
    height: 1.02rem;
  }

  .site-nav__brand {
    width: clamp(108px, 14vw, 165px);
    display: inline-flex;
    align-items: center;
  }

  .site-nav__brand img {
    width: 100%;
    height: auto;
  }

  .site-nav__menu ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    margin: 0;
    padding: 0;
  }

  .site-nav__menu a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-muted);
    border-bottom: 1px solid transparent;
    padding-bottom: 0.12rem;
  }

  .site-nav__menu a:hover {
    color: var(--color-text);
  }

  .site-nav__menu a[data-active="true"] {
    color: var(--color-accent);
    border-bottom-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
  }

  @media (max-width: 900px) {
    .site-nav {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "brand toggle"
        "menu menu";
      align-items: center;
      gap: 0.55rem 0.75rem;
      padding-top: 0.85rem;
      padding-bottom: 0.7rem;
    }

    .site-nav__brand {
      grid-area: brand;
    }

    .site-nav__toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      grid-area: toggle;
      justify-self: end;
    }

    .site-nav__menu {
      grid-area: menu;
      display: none;
      width: 100%;
      min-width: 0;
      padding-top: 0.15rem;
    }

    .site-nav[data-menu-open="true"] .site-nav__menu {
      display: block;
    }

    .site-nav__menu ul {
      display: grid;
      gap: 0.45rem;
      justify-items: start;
    }

    .site-nav__menu a {
      display: block;
      padding-bottom: 0;
      width: 100%;
    }
  }

  @media (min-width: 901px) {
    .site-nav {
      align-items: center;
    }

    .site-nav__menu {
      display: block !important;
    }
  }
</style>
