---
import { contactMailto, primaryNavLinks } from "@lib/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<div class="site-nav">
  <a class="site-nav__brand" href="/" aria-label="phi9.space home">
    <img
      src="/assets/brand/phi9-lockup-black.svg"
      alt="phi9.space"
      class="site-nav__logo site-nav__logo--desktop"
      loading="lazy"
    />
    <img
      src="/assets/brand/phi9-mark-black.svg"
      alt="phi9.space"
      class="site-nav__logo site-nav__logo--mobile"
      loading="lazy"
    />
  </a>

  <button
    type="button"
    class="site-nav__toggle"
    data-nav-toggle
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="site-nav-menu"
  >
    <span class="site-nav__toggle-lines" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>

  <nav aria-label="Primary" id="site-nav-menu" class="site-nav__menu" data-nav-menu>
    <ul>
      {primaryNavLinks.map((item) => {
        const normalizedHref = item.href.replace(/\/$/, "") || "/";
        const prefixMatch =
          currentPath === normalizedHref ||
          (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
        const shadowed = prefixMatch && primaryNavLinks.some((other) => {
          const otherHref = other.href.replace(/\/$/, "") || "/";
          return otherHref !== normalizedHref
            && otherHref.startsWith(`${normalizedHref}/`)
            && (currentPath === otherHref || currentPath.startsWith(`${otherHref}/`));
        });
        const active = prefixMatch && !shadowed;

        return (
          <li>
            <a href={item.href} data-active={active ? "true" : "false"}>
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
    <a href={contactMailto} class="site-nav__cta">Get in touch</a>
  </nav>
</div>

<script is:inline>
  const navRoot = document.querySelector(".site-nav");
  const navToggle = navRoot?.querySelector("[data-nav-toggle]");
  const navMenu = navRoot?.querySelector("[data-nav-menu]");
  const navLinks = navMenu ? Array.from(navMenu.querySelectorAll("a")) : [];

  const closeMenu = () => {
    if (!navRoot || !navToggle) return;
    navRoot.setAttribute("data-menu-open", "false");
    navToggle.setAttribute("aria-expanded", "false");
  };

  const openMenu = () => {
    if (!navRoot || !navToggle) return;
    navRoot.setAttribute("data-menu-open", "true");
    navToggle.setAttribute("aria-expanded", "true");
  };

  navToggle?.addEventListener("click", () => {
    const isOpen = navRoot?.getAttribute("data-menu-open") === "true";
    if (isOpen) closeMenu();
    else openMenu();
  });

  for (const link of navLinks) {
    link.addEventListener("click", closeMenu);
  }

  window.addEventListener("resize", () => {
    if (window.innerWidth > 800) closeMenu();
  });
</script>

<style>
  .site-nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 0.75rem clamp(1rem, 3vw, 2rem);
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .site-nav__logo {
    height: auto;
    display: block;
  }

  .site-nav__logo--desktop {
    width: clamp(138px, 16vw, 192px);
  }

  .site-nav__logo--mobile {
    display: none;
    width: 1.75rem;
  }

  .site-nav__toggle {
    display: none;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    color: var(--color-text);
    border-radius: 999px;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 10px 24px color-mix(in srgb, var(--color-text) 8%, transparent);
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .site-nav__toggle:hover {
    border-color: color-mix(in srgb, var(--color-accent) 50%, var(--color-border) 50%);
    color: var(--color-accent);
  }

  .site-nav__toggle-lines {
    position: relative;
    display: block;
    width: 1rem;
    height: 0.8rem;
  }

  .site-nav__toggle-lines span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    border-radius: 999px;
    background: currentColor;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease,
      top 0.2s ease;
  }

  .site-nav__toggle-lines span:nth-child(1) {
    top: 0;
  }

  .site-nav__toggle-lines span:nth-child(2) {
    top: calc(50% - 0.75px);
  }

  .site-nav__toggle-lines span:nth-child(3) {
    top: calc(100% - 1.5px);
  }

  .site-nav__menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-nav__menu ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    margin: 0;
    padding: 0;
  }

  .site-nav__menu a {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-nav__menu a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-nav__menu a[data-active="true"] {
    color: var(--color-accent);
  }

  .site-nav__cta {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent) !important;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .site-nav__cta:hover {
    color: var(--color-accent-hover) !important;
    text-decoration: none !important;
  }

  @media (max-width: 800px) {
    .site-nav {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "brand toggle"
        "menu menu";
      align-items: center;
      gap: 0.25rem 0.85rem;
      height: auto;
      margin: 0.6rem 0.8rem 0;
      padding: 0.75rem 0.85rem;
      background: color-mix(in srgb, var(--color-bg) 76%, transparent);
      border: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
      border-radius: 1.25rem;
      backdrop-filter: blur(22px);
      -webkit-backdrop-filter: blur(22px);
      box-shadow: 0 18px 40px rgba(22, 22, 29, 0.09);
    }

    .site-nav__brand {
      grid-area: brand;
    }

    .site-nav__logo--desktop {
      display: none;
    }

    .site-nav__logo--mobile {
      display: block;
    }

    .site-nav__toggle {
      display: inline-flex;
      grid-area: toggle;
      justify-self: end;
    }

    .site-nav__menu {
      grid-area: menu;
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      margin-top: 0.65rem;
      padding-top: 0.9rem;
      border-top: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
      width: 100%;
    }

    .site-nav[data-menu-open="true"] .site-nav__menu {
      display: flex;
    }

    .site-nav[data-menu-open="true"] {
      background: color-mix(in srgb, var(--color-bg) 88%, transparent);
      border-color: color-mix(in srgb, var(--color-accent) 22%, var(--color-border) 78%);
    }

    .site-nav[data-menu-open="true"] .site-nav__toggle {
      background: color-mix(in srgb, var(--color-accent-soft) 72%, var(--color-bg) 28%);
      border-color: color-mix(in srgb, var(--color-accent) 36%, var(--color-border) 64%);
      color: var(--color-accent);
      transform: rotate(90deg);
    }

    .site-nav[data-menu-open="true"] .site-nav__toggle-lines span:nth-child(1) {
      top: calc(50% - 0.75px);
      transform: rotate(45deg);
    }

    .site-nav[data-menu-open="true"] .site-nav__toggle-lines span:nth-child(2) {
      opacity: 0;
    }

    .site-nav[data-menu-open="true"] .site-nav__toggle-lines span:nth-child(3) {
      top: calc(50% - 0.75px);
      transform: rotate(-45deg);
    }

    .site-nav__menu ul {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
      align-items: flex-start;
      width: 100%;
    }

    .site-nav__menu li,
    .site-nav__menu a {
      width: 100%;
    }

    .site-nav__menu a {
      font-size: 1rem;
    }

    .site-nav__cta {
      margin-top: 0.15rem;
      padding-top: 0.45rem;
    }
  }
</style>
