---
import { contactMailto, primaryNavLinks } from "@lib/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<div class="site-nav">
  <a class="site-nav__brand" href="/" aria-label="phi9.space home">
    <img src="/assets/brand/phi9-wordmark.svg" alt="phi9.space" class="site-nav__logo" loading="lazy" />
  </a>

  <button
    type="button"
    class="site-nav__toggle"
    data-nav-toggle
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="site-nav-menu"
  >
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
    </svg>
  </button>

  <nav aria-label="Primary" id="site-nav-menu" class="site-nav__menu" data-nav-menu>
    <ul>
      {primaryNavLinks.map((item) => {
        const normalizedHref = item.href.replace(/\/$/, "") || "/";
        const prefixMatch =
          currentPath === normalizedHref ||
          (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
        const shadowed = prefixMatch && primaryNavLinks.some((other) => {
          const otherHref = other.href.replace(/\/$/, "") || "/";
          return otherHref !== normalizedHref
            && otherHref.startsWith(`${normalizedHref}/`)
            && (currentPath === otherHref || currentPath.startsWith(`${otherHref}/`));
        });
        const active = prefixMatch && !shadowed;

        return (
          <li>
            <a href={item.href} data-active={active ? "true" : "false"}>
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
    <a href={contactMailto} class="site-nav__cta">Get in touch</a>
  </nav>
</div>

<script is:inline>
  const navRoot = document.querySelector(".site-nav");
  const navToggle = navRoot?.querySelector("[data-nav-toggle]");
  const navMenu = navRoot?.querySelector("[data-nav-menu]");
  const navLinks = navMenu ? Array.from(navMenu.querySelectorAll("a")) : [];

  const closeMenu = () => {
    if (!navRoot || !navToggle) return;
    navRoot.setAttribute("data-menu-open", "false");
    navToggle.setAttribute("aria-expanded", "false");
  };

  const openMenu = () => {
    if (!navRoot || !navToggle) return;
    navRoot.setAttribute("data-menu-open", "true");
    navToggle.setAttribute("aria-expanded", "true");
  };

  navToggle?.addEventListener("click", () => {
    const isOpen = navRoot?.getAttribute("data-menu-open") === "true";
    if (isOpen) closeMenu();
    else openMenu();
  });

  for (const link of navLinks) {
    link.addEventListener("click", closeMenu);
  }

  window.addEventListener("resize", () => {
    if (window.innerWidth > 800) closeMenu();
  });
</script>

<style>
  .site-nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 0.75rem clamp(1rem, 3vw, 2rem);
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .site-nav__logo {
    width: clamp(138px, 16vw, 192px);
    height: auto;
    display: block;
  }

  .site-nav__toggle {
    display: none;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: var(--radius-sm);
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .site-nav__toggle svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .site-nav__menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-nav__menu ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    margin: 0;
    padding: 0;
  }

  .site-nav__menu a {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-nav__menu a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-nav__menu a[data-active="true"] {
    color: var(--color-accent);
  }

  .site-nav__cta {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text) !important;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .site-nav__cta:hover {
    color: var(--color-accent) !important;
    text-decoration: none !important;
  }

  @media (max-width: 800px) {
    .site-nav {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "brand toggle"
        "menu menu";
      align-items: center;
      gap: 0;
      height: auto;
      padding-top: 0.85rem;
      padding-bottom: 0.85rem;
    }

    .site-nav__brand {
      grid-area: brand;
    }

    .site-nav__toggle {
      display: inline-flex;
      grid-area: toggle;
      justify-self: end;
    }

    .site-nav__menu {
      grid-area: menu;
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
      padding-top: 0.75rem;
    }

    .site-nav[data-menu-open="true"] .site-nav__menu {
      display: flex;
    }

    .site-nav__menu ul {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
    }

    .site-nav__cta {
      margin-top: 0.25rem;
    }
  }
</style>
