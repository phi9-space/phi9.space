---
interface Props {
	title: string;
	dek?: string | null;
	leadTag?: string | null;
	readingTime?: number | null;
	publishedLabel?: string | null;
	updatedLabel?: string | null;
	authorLabel?: string | null;
}

const {
	title,
	dek = null,
	leadTag = null,
	readingTime = null,
	publishedLabel = null,
	updatedLabel = null,
	authorLabel = null,
} = Astro.props as Props;

const metaItems = [leadTag, readingTime ? `${readingTime} min` : null].filter(Boolean) as string[];
const hasSidebar = Boolean(publishedLabel || updatedLabel || authorLabel);
const hasHero = Astro.slots.has("hero");
---

<article class="article">
  {metaItems.length > 0 && (
    <div class="article__meta">
      {metaItems.map((item, index) => (
        <>
          {index > 0 && <span>·</span>}
          <span>{item}</span>
        </>
      ))}
    </div>
  )}

  <h1 class="article__title">{title}</h1>
  {dek && <p class="article__dek">{dek}</p>}

  {hasHero && (
    <div class="article__hero">
      <slot name="hero" />
    </div>
  )}

  <div class:list={{ "article__grid": true, "article__grid--single": !hasSidebar, container: true }}>
    {hasSidebar && (
      <aside class="article__sidebar">
        {publishedLabel && (
          <div class="article__sidebar-group">
            <span class="article__sidebar-label">Published</span>
            <span class="article__sidebar-value">{publishedLabel}</span>
          </div>
        )}

        {updatedLabel && (
          <div class="article__sidebar-group">
            <span class="article__sidebar-label">Updated</span>
            <span class="article__sidebar-value">{updatedLabel}</span>
          </div>
        )}

        {authorLabel && (
          <div class="article__sidebar-group">
            <span class="article__sidebar-label">Author</span>
            <span class="article__sidebar-value">{authorLabel}</span>
          </div>
        )}
      </aside>
    )}

    <div class="article__body">
      <slot />
    </div>
  </div>
</article>

<style>
  .article {
    padding-top: clamp(6rem, 10vw, 8rem);
  }

  .article__meta {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    padding: 0 clamp(1rem, 3vw, 2rem);
    margin-bottom: 1.25rem;
  }

  .article__title {
    font-size: clamp(2rem, 4vw, 3rem);
    text-align: center;
    max-width: 20ch;
    margin: 0 auto 1rem;
    padding: 0 clamp(1rem, 3vw, 2rem);
  }

  .article__dek {
    margin: 0 auto 3rem;
    text-align: center;
    max-width: 42rem;
    padding: 0 clamp(1rem, 3vw, 2rem);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .article__hero {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto 3rem;
    padding: 0 clamp(1rem, 3vw, 2rem);
  }

  .article__hero :global(img),
  .article__hero :global(video) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-lg);
  }

  .article__grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem;
    align-items: start;
    padding-bottom: 4rem;
  }

  .article__grid--single {
    grid-template-columns: 1fr;
  }

  .article__sidebar {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding-top: 0.25rem;
  }

  .article__sidebar-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .article__sidebar-label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .article__sidebar-value {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .article__body {
    max-width: 680px;
  }

  .article__body :global(p),
  .article__body :global(ul),
  .article__body :global(ol) {
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .article__body :global(p),
  .article__body :global(ul),
  .article__body :global(ol),
  .article__body :global(blockquote),
  .article__body :global(dl),
  .article__body :global(hr) {
    max-width: var(--measure-reading);
  }

  .article__body :global(h1),
  .article__body :global(h2),
  .article__body :global(h3),
  .article__body :global(h4),
  .article__body :global(h5),
  .article__body :global(h6) {
    max-width: 34ch;
  }

  .article__body :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .article__body :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .article__body :global(blockquote) {
    line-height: 1.6;
  }

  .article__body :global(img),
  .article__body :global(video) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: 1.5rem 0;
  }

  .article__body :global(pre),
  .article__body :global(table),
  .article__body :global(figure) {
    max-width: min(100%, 960px);
  }

  .article__body :global(ul[data-task-list]) {
    list-style: none;
    padding-left: 0.2rem;
  }

  .article__body :global(ul[data-task-list] li) {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .article__body :global(ul[data-task-list] input[type="checkbox"]) {
    margin-top: 0.28rem;
  }

  .article__body :global(table) {
    font-size: 0.9rem;
  }

  .article__body :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }

  .article__body :global(a) {
    color: var(--color-accent);
    text-underline-offset: 0.16em;
  }

  @media (max-width: 800px) {
    .article__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .article__sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
