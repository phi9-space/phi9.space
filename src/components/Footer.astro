---
import { footerLinkGroups, siteBrandCopy } from "@lib/site";
---

<footer class="site-footer">
  <div class="site-footer__inner container">
    <div class="site-footer__columns">
      <div class="site-footer__brand">
        <p class="site-footer__brand-copy">{siteBrandCopy}</p>
        <p class="site-footer__copyright">© {new Date().getFullYear()} phi9.space</p>
      </div>

      {footerLinkGroups.map((group) => (
        <div class="site-footer__col">
          <span class="site-footer__col-title">{group.title}</span>
          {group.links.map((link) => (
            <a href={link.href} rel={link.external ? "noreferrer" : undefined} target={link.external ? "_blank" : undefined}>
              {link.label}
            </a>
          ))}
        </div>
      ))}
    </div>

    <div class="site-footer__banner">
      <a href="/" aria-label="phi9.space home" class="site-footer__banner-link">
        <img src="/assets/brand/phi9-lockup-black.svg" alt="phi9.space" class="site-footer__banner-logo" loading="lazy" />
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: clamp(2.75rem, 5vw, 4rem) 0 2rem;
    border-top: 1px solid var(--color-border);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-top: 0.25rem;
  }

  .site-footer__columns {
    display: grid;
    grid-template-columns: minmax(220px, 1.3fr) repeat(4, minmax(120px, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .site-footer__banner-link {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
  }

  .site-footer__banner-logo {
    width: 100%;
    height: auto;
    display: block;
  }

  .site-footer__brand {
    display: grid;
    gap: 0.35rem;
    align-content: start;
  }

  .site-footer__brand-copy,
  .site-footer__copyright {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-muted);
    max-width: 28ch;
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .site-footer__col-title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .site-footer__col a {
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .site-footer__col a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  @media (max-width: 960px) {
    .site-footer__columns {
      grid-template-columns: repeat(2, minmax(160px, 1fr));
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .site-footer__columns {
      grid-template-columns: 1fr;
    }
  }
</style>
