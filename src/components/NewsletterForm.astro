---
interface Props {
	publication?: string;
	placeholder?: string;
	submitLabel?: string;
	class?: string;
}

const {
	publication = "phi9",
	placeholder = "you@email.com",
	submitLabel = "Subscribe",
	class: className = "",
} = Astro.props;

const action = `https://${publication}.substack.com/subscribe`;
---

<form
	class:list={["newsletter-form", className]}
	action={action}
	method="GET"
	target="_blank"
	rel="noopener"
>
	<label class="newsletter-form__label" for="newsletter-email">Email</label>
	<div class="newsletter-form__row">
		<input
			id="newsletter-email"
			class="newsletter-form__input"
			type="email"
			name="email"
			placeholder={placeholder}
			required
			autocomplete="email"
			spellcheck="false"
		/>
		<button type="submit" class="newsletter-form__submit">
			{submitLabel}
		</button>
	</div>
	<p class="newsletter-form__note">
		One click. Email opens Substack to confirm.
	</p>
</form>

<style>
	.newsletter-form {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		max-width: 32rem;
		margin: 0 auto;
		text-align: left;
	}

	.newsletter-form__label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.newsletter-form__row {
		display: flex;
		align-items: stretch;
		gap: 0.75rem;
		border-bottom: 1.5px solid var(--color-text);
		padding-bottom: 0.35rem;
	}

	.newsletter-form__input {
		flex: 1;
		min-width: 0;
		border: none;
		background: transparent;
		padding: 0.55rem 0;
		font-family: var(--font-body);
		font-size: 1.05rem;
		color: var(--color-text);
	}

	.newsletter-form__input::placeholder {
		color: color-mix(in srgb, var(--color-muted) 65%, transparent);
	}

	.newsletter-form__input:focus {
		outline: none;
	}

	.newsletter-form__submit {
		display: inline-flex;
		align-items: center;
		padding: 0.55rem 1.1rem;
		border: none;
		background: var(--color-text);
		color: var(--color-bg);
		font-family: var(--font-mono);
		font-size: 0.82rem;
		letter-spacing: 0.05em;
		cursor: pointer;
		transition:
			background 0.2s ease,
			color 0.2s ease;
	}

	.newsletter-form__submit:hover {
		background: var(--color-accent);
		color: var(--color-text-inverse);
	}

	.newsletter-form__note {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		color: var(--color-muted);
	}

	@media (max-width: 520px) {
		.newsletter-form__row {
			flex-direction: column;
			align-items: stretch;
			border-bottom: none;
			gap: 0.75rem;
			padding-bottom: 0;
		}

		.newsletter-form__input {
			border-bottom: 1.5px solid var(--color-text);
			padding: 0.6rem 0;
		}

		.newsletter-form__submit {
			justify-content: center;
		}
	}
</style>
