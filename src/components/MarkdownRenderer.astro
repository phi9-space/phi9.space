---
interface Props {
	Content: any;
	raw?: string;
}

const { Content } = Astro.props as Props;
---

<div class="wiki-note">
  <div class="wiki-note__content">
    <Content />
  </div>
</div>

<style>
  .wiki-note__content {
    display: grid;
    gap: 0.15rem;
  }

  .wiki-note__content :global(p),
  .wiki-note__content :global(ul),
  .wiki-note__content :global(ol),
  .wiki-note__content :global(blockquote),
  .wiki-note__content :global(dl),
  .wiki-note__content :global(hr) {
    max-width: var(--measure-reading);
  }

  .wiki-note__content :global(h1),
  .wiki-note__content :global(h2),
  .wiki-note__content :global(h3),
  .wiki-note__content :global(h4),
  .wiki-note__content :global(h5),
  .wiki-note__content :global(h6) {
    max-width: 34ch;
  }

  .wiki-note__content :global(pre),
  .wiki-note__content :global(table),
  .wiki-note__content :global(figure),
  .wiki-note__content :global(.external-embed),
  .wiki-note__content :global(.vault-media) {
    max-width: min(100%, 960px);
  }

  .wiki-note__content :global(ul[data-task-list]) {
    list-style: none;
    padding-left: 0.2rem;
  }

  .wiki-note__content :global(ul[data-task-list] li) {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .wiki-note__content :global(ul[data-task-list] input[type="checkbox"]) {
    margin-top: 0.28rem;
  }
</style>
