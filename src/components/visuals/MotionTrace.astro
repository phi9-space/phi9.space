---
interface Props {
	width?: string;
	height?: string;
	color?: string;
	class?: string;
}

const {
	width = "2.5rem",
	height = "2rem",
	color = "var(--color-accent)",
	class: className = "",
} = Astro.props;
---

<svg
	class:list={["motion-trace", className]}
	style={`--trace-width: ${width}; --trace-height: ${height}; --trace-color: ${color};`}
	viewBox="0 0 96 64"
	fill="none"
	aria-hidden="true"
>
	<path d="M6 42C18 18 32 18 44 42C56 60 70 58 90 18" pathLength="100" />
	<path d="M6 54C20 30 34 30 46 52C58 66 72 62 90 34" pathLength="100" />
	<circle cx="16" cy="33" r="3.5" />
	<circle cx="90" cy="18" r="4" />
</svg>

<style>
	.motion-trace {
		width: var(--trace-width);
		height: var(--trace-height);
		display: block;
	}

	.motion-trace path {
		stroke: var(--trace-color);
		stroke-width: 4;
		stroke-linecap: round;
		stroke-linejoin: round;
		opacity: 0.78;
		stroke-dasharray: 100;
		stroke-dashoffset: 0;
	}

	.motion-trace path:last-of-type {
		opacity: 0.34;
	}

	.motion-trace circle {
		fill: var(--trace-color);
	}

	@media (prefers-reduced-motion: no-preference) {
		.motion-trace path {
			animation: trace-draw 2.8s ease-in-out infinite alternate;
		}

		.motion-trace path:last-of-type {
			animation-delay: 0.2s;
		}
	}

	@keyframes trace-draw {
		from {
			stroke-dashoffset: 110;
		}

		to {
			stroke-dashoffset: 0;
		}
	}
</style>
