---
interface Props {
	width?: string;
	height?: string;
	color?: string;
	class?: string;
}

const {
	width = "2.6rem",
	height = "2rem",
	color = "var(--color-text)",
	class: className = "",
} = Astro.props;
---

<svg
	class:list={["train-waveform", className]}
	style={`--wave-width: ${width}; --wave-height: ${height}; --wave-color: ${color};`}
	viewBox="0 0 96 64"
	fill="none"
	aria-hidden="true"
>
	<rect x="4" y="6" width="84" height="52" rx="12" />
	<path class="train-waveform__foreground" d="M4 42L18 20L32 42L46 14L60 42L74 24L88 42" pathLength="100" />
	<path class="train-waveform__echo" d="M4 54L18 34L32 54L46 28L60 54L74 40L88 54" pathLength="100" />
</svg>

<style>
	.train-waveform {
		width: var(--wave-width);
		height: var(--wave-height);
		display: block;
	}

	.train-waveform path {
		stroke: var(--wave-color);
		stroke-width: 4;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.train-waveform__echo {
		opacity: 0.35;
	}

	.train-waveform rect {
		stroke: color-mix(in srgb, var(--wave-color) 28%, transparent);
		stroke-width: 2;
	}

	@media (prefers-reduced-motion: no-preference) {
		.train-waveform__foreground,
		.train-waveform__echo {
			stroke-dasharray: 110;
			animation: wave-scroll 3.2s linear infinite;
		}

		.train-waveform__echo {
			animation-delay: 0.4s;
		}
	}

	@keyframes wave-scroll {
		from {
			stroke-dashoffset: 220;
		}
		to {
			stroke-dashoffset: 0;
		}
	}
</style>
