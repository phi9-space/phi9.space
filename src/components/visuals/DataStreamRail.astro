---
import BraillePulse from "./BraillePulse.astro";

interface Props {
	items?: string[];
	speed?: string;
	class?: string;
	bordered?: boolean;
	variant?: "accent" | "muted";
}

const {
	items = [
		"REAL-TIME SYNC",
		"MULTI-MODAL CAPTURE",
		"IMU",
		"EGO-CENTRIC VIDEO",
		"DOMAIN-DIVERSE DATA",
		"PRETRAINING DATA",
		"POLICY TRAINING DATA",
		"WORLD-MODEL DATA",
		"RETARGETING",
		"TASK LABELS",
		"EVALUATION TRACES",
	],
	speed = "140s",
	class: className = "",
	bordered = true,
	variant = "accent",
} = Astro.props;

// Render the same set twice so the animation loops seamlessly.
const chunks = [items, items];
---

<div class:list={["data-rail-wrap container", className]} aria-hidden="true">
	<div class:list={["data-rail", bordered ? "data-rail--bordered" : "", `data-rail--${variant}`]}>
		<div class="data-rail__track" style={`--rail-speed: ${speed};`}>
			{chunks.map((chunk) => (
				<span class="data-rail__chunk">
					{chunk.map((item) => (
						<>
							<span class="data-rail__label">{item}</span>
							<span class="data-rail__pulse"><BraillePulse /></span>
						</>
					))}
				</span>
			))}
		</div>
	</div>
</div>

<style>
	.data-rail-wrap {
		width: 100%;
	}

	.data-rail {
		overflow: hidden;
		width: 100%;
		padding: 0.7rem 0;
	}

	.data-rail--bordered {
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.data-rail__track {
		display: flex;
		white-space: nowrap;
		width: max-content;
		animation: rail-scroll var(--rail-speed) linear infinite;
		will-change: transform;
	}

	.data-rail__chunk {
		display: inline-flex;
		align-items: center;
		gap: 1.2rem;
		padding-right: 1.2rem;
	}

	.data-rail__label {
		font-family: var(--font-mono);
		font-size: 0.76rem;
		letter-spacing: 0.2em;
		color: var(--color-muted);
	}

	.data-rail__pulse {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.9rem;
	}

	.data-rail--accent .data-rail__pulse {
		color: var(--color-accent);
	}

	.data-rail--muted .data-rail__pulse {
		color: var(--color-muted);
	}

	.data-rail--muted .data-rail__label {
		color: color-mix(in srgb, var(--color-text) 72%, transparent);
	}

	@keyframes rail-scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.data-rail__track {
			animation: none;
		}
	}
</style>
