---
interface Props {
	width?: string;
	height?: string;
	color?: string;
	accent?: string;
	class?: string;
}

const {
	width = "2.4rem",
	height = "2rem",
	color = "var(--color-text)",
	accent = "var(--color-accent)",
	class: className = "",
} = Astro.props;
---

<div
	class:list={["benchmark-bars", className]}
	style={`--bars-width: ${width}; --bars-height: ${height}; --bars-color: ${color}; --bars-accent: ${accent};`}
	aria-hidden="true"
>
	<span></span>
	<span></span>
	<span></span>
	<span></span>
</div>

<style>
	.benchmark-bars {
		width: var(--bars-width);
		height: var(--bars-height);
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		align-items: end;
		gap: 0.22rem;
	}

	.benchmark-bars span {
		display: block;
		background: color-mix(in srgb, var(--bars-color) 22%, transparent);
		border-radius: 999px 999px 0 0;
		height: 35%;
		transform-origin: bottom;
	}

	.benchmark-bars span:nth-child(1) {
		height: 42%;
	}

	.benchmark-bars span:nth-child(2) {
		height: 64%;
	}

	.benchmark-bars span:nth-child(3) {
		height: 100%;
		background: var(--bars-accent);
	}

	.benchmark-bars span:nth-child(4) {
		height: 76%;
	}

	@media (prefers-reduced-motion: no-preference) {
		.benchmark-bars span {
			animation: bar-breathe 3.2s ease-in-out infinite;
		}

		.benchmark-bars span:nth-child(2) {
			animation-delay: 0.15s;
		}

		.benchmark-bars span:nth-child(3) {
			animation-delay: 0.3s;
			animation-duration: 2.4s;
		}

		.benchmark-bars span:nth-child(4) {
			animation-delay: 0.45s;
		}
	}

	@keyframes bar-breathe {
		0%,
		100% {
			transform: scaleY(1);
			opacity: 1;
		}
		50% {
			transform: scaleY(0.82);
			opacity: 0.85;
		}
	}
</style>
