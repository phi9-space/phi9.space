---
import type { CollectionEntry } from "astro:content";
import ContactCTA from "@components/ContactCTA.astro";
import LongformArticleShell from "@components/LongformArticleShell.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatLongDate, getReadingTime } from "@lib/site";

interface Props {
	entry: CollectionEntry<"pages">;
	Content: any;
	eyebrow?: string;
	showContactCTA?: boolean;
	contactHeadline?: string;
	contactBody?: string;
	contactSecondaryHref?: string;
	contactSecondaryLabel?: string;
}

const {
	entry,
	Content,
	eyebrow = "Document",
	showContactCTA = false,
	contactHeadline,
	contactBody,
	contactSecondaryHref,
	contactSecondaryLabel,
} = Astro.props as Props;
const publishedDate = entry.data.published ?? entry.data.updated ?? null;
const publishedLabel = publishedDate ? formatLongDate(publishedDate) : null;
const updatedLabel = entry.data.updated && publishedDate && entry.data.updated.valueOf() !== publishedDate.valueOf()
	? formatLongDate(entry.data.updated)
	: null;
const readingTime = getReadingTime(entry.body);
const authorLabel = entry.data.author ?? "Phi9";
// The richer heroSubtitle is the poster-grade headline when present; the
// bare title (e.g. "About", "Data") moves into the eyebrow slot.
const displayHeadline = entry.data.heroSubtitle ?? entry.data.title;
const eyebrowLabel = entry.data.heroSubtitle ? entry.data.title : eyebrow;
const dek = entry.data.heroSubtitle ? entry.data.description : null;
---

<BaseLayout
	fullWidth={true}
	title={`${entry.data.title} — phi9.space`}
	description={entry.data.description}
	pageType="article"
>
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" />

  <LongformArticleShell
    title={displayHeadline}
    dek={dek}
    leadTag={eyebrowLabel}
    readingTime={readingTime}
    publishedLabel={publishedLabel}
    updatedLabel={updatedLabel}
    authorLabel={authorLabel}
  >
    <Content />
  </LongformArticleShell>

  {showContactCTA && (
    <ContactCTA
      headline={contactHeadline}
      body={contactBody}
      secondaryHref={contactSecondaryHref}
      secondaryLabel={contactSecondaryLabel}
    />
  )}
</BaseLayout>
